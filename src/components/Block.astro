---
// Renders ONE section by routing to the appropriate sub-component in blocks/.
// To add a new section type:
//   1. Add it to content.config.ts (the schema is the source of truth).
//   2. Create src/components/blocks/<Type>Block.astro.
//   3. Add it to the import list and the routing below.
//   4. Update the `carded` list if the type should render inside a .card wrapper.
import PanelBlock  from "./blocks/PanelBlock.astro";
import ProseBlock  from "./blocks/ProseBlock.astro";
import ListBlock   from "./blocks/ListBlock.astro";
import RoutesBlock from "./blocks/RoutesBlock.astro";
import MapBlock    from "./blocks/MapBlock.astro";
import BudgetBlock from "./blocks/BudgetBlock.astro";
import DaysBlock   from "./blocks/DaysBlock.astro";
import SightsBlock from "./blocks/SightsBlock.astro";
import RaidBlock   from "./blocks/RaidBlock.astro";

const { sec, sid, ci, solo } = Astro.props;

const titleText = solo ? "" : (sec.title || "");

// Types that render their content inside a shared .card wrapper.
// days and sights render their own per-item .card elements instead.
const carded = ["panel", "prose", "list", "routes", "map", "budget", "raids"].includes(sec.type);
---
<section class="block" id={sid} data-cat={ci}>
  {carded ? (
    <div class="card">
      {titleText && <h3 class="block-title">{titleText}</h3>}
      {sec.type === "panel"  && <PanelBlock  sec={sec} />}
      {sec.type === "prose"  && <ProseBlock  sec={sec} />}
      {sec.type === "list"   && <ListBlock   sec={sec} />}
      {sec.type === "routes" && <RoutesBlock sec={sec} />}
      {sec.type === "map"    && <MapBlock    sec={sec} />}
      {sec.type === "budget" && <BudgetBlock sec={sec} />}
      {sec.type === "raids"  && <RaidBlock   sec={sec} />}
    </div>
  ) : (
    <>
      {titleText && <h3 class="block-title">{titleText}</h3>}
      {sec.type === "days"   && <DaysBlock   sec={sec} />}
      {sec.type === "sights" && <SightsBlock sec={sec} />}
    </>
  )}
</section>
