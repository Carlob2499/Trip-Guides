---
import { getImage } from "astro:assets";

// Renders ONE section. This is a direct port of the original renderer, so the
// markup (and therefore the styling) is identical to your hand-built guides.
const { sec, sid, ci, solo } = Astro.props;

const titleText = solo ? "" : (sec.title || "");
const carded = ["panel", "prose", "list", "routes", "map"].includes(sec.type);

const commonsSrc  = (file: string) => `https://commons.wikimedia.org/wiki/Special:FilePath/${encodeURIComponent(file)}?width=1200`;
const commonsPage = (file: string) => `https://commons.wikimedia.org/wiki/File:${encodeURIComponent(file)}`;
const gmaps = (m: any) => `https://www.google.com/maps/search/?api=1&query=${m.lat},${m.lng}`;
const bbox = (c: any, span?: number) => { const s = span || 0.05; return [c.lng - s, c.lat - s * 0.6, c.lng + s, c.lat + s * 0.6].join("%2C"); };

// Pre-optimise each sight photo into responsive WebP. If the build server can't
// reach Wikimedia (e.g. this preview sandbox), we quietly fall back to the plain
// photo — the page still renders, just unoptimised.
const opt: Record<string, any> = {};
if (sec.type === "sights") {
  for (const it of (sec.items || [])) {
    if (it.img && it.img.file && !(it.img.file in opt)) {
      try {
        opt[it.img.file] = await getImage({
          src: commonsSrc(it.img.file),
          widths: [480, 800, 1200],
          format: "webp",
          inferSize: true,
        });
      } catch {
        opt[it.img.file] = null;
      }
    }
  }
}
---
<section class="block" id={sid} data-cat={ci}>
  {carded ? (
    <div class="card">
      {titleText && <h3 class="block-title">{titleText}</h3>}

      {sec.type === "panel" && (
        <>
          {sec.body && <Fragment set:html={sec.body} />}
          {(sec.checklist || []).map((i: string) => (
            <label class="check"><input type="checkbox" /> <Fragment set:html={i} /></label>
          ))}
        </>
      )}

      {sec.type === "prose" && sec.body && <Fragment set:html={sec.body} />}

      {sec.type === "list" && (sec.items || []).map((i: string) => (
        <label class="check"><input type="checkbox" /> <Fragment set:html={i} /></label>
      ))}

      {sec.type === "routes" && (
        <ol class="steps">
          {(sec.steps || []).map((s: string) => (<li><Fragment set:html={s} /></li>))}
        </ol>
      )}

      {sec.type === "map" && (
        <>
          <iframe class="osmmap" loading="lazy" title="map"
            src={`https://www.openstreetmap.org/export/embed.html?bbox=${bbox(sec.center, sec.span)}&layer=mapnik&marker=${sec.center.lat}%2C${sec.center.lng}`}></iframe>
          <p class="note">Interactive map — pan &amp; zoom when you open this guide in a browser.</p>
        </>
      )}
    </div>
  ) : (
    <>
      {titleText && <h3 class="block-title">{titleText}</h3>}

      {sec.type === "days" && (sec.items || []).map((d: any) => (
        <div class="day">
          <div class="d">{d.date}</div>
          <div class="b">
            <strong>{d.title}</strong>
            {d.pace && <div class="pace">⏱ {d.pace}</div>}
            {d.body && <div><Fragment set:html={d.body} /></div>}
            {d.note && <span class="lsnote">🌿 <Fragment set:html={d.note} /></span>}
            {d.fit && <div class="fit">Fit: <Fragment set:html={d.fit} /></div>}
            {d.checklist && d.checklist.length > 0 && (
              <div class="daykit">
                <span class="kit-label">Day kit</span>
                {d.checklist.map((i: string) => (
                  <label class="check"><input type="checkbox" /> <Fragment set:html={i} /></label>
                ))}
              </div>
            )}
          </div>
        </div>
      ))}

      {sec.type === "sights" && (sec.items || []).map((it: any) => {
        const o = it.img ? opt[it.img.file] : null;
        return (
          <div class="card sight">
            {it.img && (o ? (
              <img class="cardimg" loading="lazy" alt={it.img.alt || ""}
                src={o.src} srcset={o.srcSet.attribute}
                sizes="(max-width:899px) 100vw, 760px"
                width={o.attributes.width} height={o.attributes.height}
                onerror="this.classList.add('imgfail')" />
            ) : (
              <img class="cardimg" loading="lazy" alt={it.img.alt || ""}
                onerror="this.classList.add('imgfail')" src={commonsSrc(it.img.file)} />
            ))}
            {it.img && (
              <span class="imgcredit"><a href={commonsPage(it.img.file)} target="_blank" rel="noopener">Photo: Wikimedia Commons ↗</a></span>
            )}
            {it.kicker && <span class="tag">{it.kicker}</span>}
            <h4 class="sight-name">{it.name}</h4>
            <p>
              <Fragment set:html={it.body || ""} />
              {it.map && <> <a class="maplink" target="_blank" rel="noopener" href={gmaps(it.map)}>Map ↗</a></>}
            </p>
          </div>
        );
      })}
    </>
  )}
</section>
