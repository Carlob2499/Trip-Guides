---
/* Trip Learnings — capture (P1) + reality layer (P2/P3). Renders:
   · the hidden survey-modal shell (the "Trip Feedback" trigger lives at the foot of the
     itinerary in GuideLayout),
   · the #tripLearn special-panel (the Learnings tab) — a sibling of #tripSplit / #tripVote,
     hidden until Firebase has ≥1 feedback record for this guide (tab.js reveals its gtab).
   Everything stays inert until Firebase is configured (the silo gates on hasFirebase()). */
import "../features/learnings/styles.css";
import { tallySkipsByGroup } from "../features/learnings/index.js";
interface Props { storeKey: string; learnings?: any; slug: string; title?: string }
const { storeKey, learnings = null, slug, title = "" } = Astro.props;
// Which parts of the guide didn't survive contact, by declared group. Empty unless the
// post-mortem tagged its skipped stops — no data, no heading (the honest-blank rule).
const skipTally = tallySkipsByGroup(learnings?.days);
// The recap card (docs/FEATURES.md #10) exists ONLY for guides with a post-trip
// `learnings.days` entry — src/pages/recap/[slug].png.ts's own getStaticPaths
// filters the same way, so this link never 404s.
const hasRecap = (learnings?.days ?? []).length > 0;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const recapUrl = `${base}/recap/${slug}.png`;
---
<div class="lnw-modal" id="lnwModal" data-sk={storeKey} hidden aria-hidden="true">
  <div class="lnw-backdrop" data-lnw-close aria-hidden="true"></div>
  <div class="lnw-dialog" role="dialog" aria-modal="true" aria-labelledby="lnwTitle" tabindex="-1">
    <button class="lnw-x" type="button" data-lnw-close aria-label="Close feedback">×</button>
    <p class="lnw-eyebrow">Trip feedback</p>
    <h2 class="lnw-title" id="lnwTitle">How did the plan hold up?</h2>
    <div class="lnw-body" id="lnwBody"></div>
    <div class="lnw-nav" id="lnwNav"></div>
  </div>
</div>

<section class="learn-wrap" id="tripLearn" role="tabpanel" aria-labelledby="gtab-learn" data-sk={storeKey} hidden>
  <div class="learn-head">
    <div>
      <p class="learn-eyebrow">Trip learnings</p>
      <h2 class="learn-title">How the plan actually went</h2>
    </div>
    <button class="learn-x" type="button" data-learn-dismiss aria-label="Hide learnings for now">×</button>
  </div>
  <div class="learn-agg" id="learnAgg"></div>
  {/* Curated post-mortem — server-rendered guide data (never travelers' verbatim
      critiques). Empty unless the guide carries `learnings`; tab.js treats a
      non-empty #learnCurated as its own unlock. */}
  <div class="learn-curated" id="learnCurated">
    {learnings?.summary && <p class="learn-actually"><Fragment set:html={learnings.summary} /></p>}
    {(learnings?.days ?? []).map((d: any) => (
      <div class="learn-day">
        <p class="learn-day-date">{d.date}</p>
        {d.actually && <p class="learn-actually"><Fragment set:html={d.actually} /></p>}
        {(d.skipped ?? []).length > 0 && (
          <ul class="learn-skips">
            {d.skipped.map((s: any) => (
              <li>
                <span class="learn-skip-stop">✗ {s.stop}</span>
                {s.reason && <span class="learn-skip-why">{s.reason}</span>}
              </li>
            ))}
          </ul>
        )}
      </div>
    ))}
    {skipTally.length > 0 && (
      <>
        <p class="learn-sub">What didn't survive contact</p>
        <p class="learn-tally-note">Planned stops that didn't happen, by section. Counts only — the plan records what was skipped, not what was attempted.</p>
        <ul class="learn-tally">
          {skipTally.map((t) => (
            <li class="learn-tally-row">
              <span class="learn-tally-group">{t.group}</span>
              <span class="learn-tally-count">{t.count}</span>
            </li>
          ))}
        </ul>
      </>
    )}
    {(learnings?.keyLearnings ?? []).length > 0 && (
      <>
        <p class="learn-sub">What we learned</p>
        <ul class="learn-key">{learnings.keyLearnings.map((t: string) => <li><Fragment set:html={t} /></li>)}</ul>
      </>
    )}
    {(learnings?.changed ?? []).length > 0 && (
      <>
        <p class="learn-sub">What I changed in this guide</p>
        <ul class="learn-changed">{learnings.changed.map((t: string) => <li><Fragment set:html={t} /></li>)}</ul>
      </>
    )}
    {learnings?.verified_on && <p class="learn-day-date">Post-mortem written {learnings.verified_on}</p>}
  </div>
  <div class="learn-foot">
    <button class="lnw-open lnw-open-inline" type="button" data-lnw-open>
      <span class="lnw-open-ico" aria-hidden="true">✎</span>Add trip feedback
    </button>
    {hasRecap && (
      <a class="lnw-open lnw-open-inline learn-recap-btn" href={recapUrl} target="_blank" rel="noopener" download={`${(title || "trip").replace(/\W+/g, "-").toLowerCase()}-recap.png`}>
        <span class="lnw-open-ico" aria-hidden="true">🖼</span>Share your trip recap
      </a>
    )}
  </div>
</section>

<script>
  import { initLearnings } from "../features/learnings/index.js";
  // Module scripts run deferred, but guard anyway so the itinerary DOM (the stop list
  // the survey reads) is present before we wire up.
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", () => initLearnings(), { once: true });
  } else {
    initLearnings();
  }
</script>
