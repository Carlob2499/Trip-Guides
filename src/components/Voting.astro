---
interface Props {
  storeKey: string;
}
const { storeKey } = Astro.props;
---

<!-- Reuses Budget Calculator's box/button/card CSS (.split-*, .sc-*, .se-new-card) —
     purely presentational styles, nothing money-specific about them. -->
<div class="split-wrap" id="tripVote" role="tabpanel" aria-labelledby="gtab-vote" hidden data-sk={storeKey}>

  <div class="split-toolbar">
    <h2 class="split-title">Group Vote</h2>
    <p class="split-desc">Propose a few options, pass the phone around, tap +1 for your pick — no chat thread to dig through later.</p>
    <div class="split-save-actions">
      <button class="sc-add-btn" id="voSyncLink" type="button">🔗 Copy vote link</button>
      <button class="sc-add-btn" id="voQrBtn" type="button" aria-expanded="false">▦ Show QR</button>
    </div>
    <div class="share-qr-wrap" id="voQrBox" hidden>
      <div id="voQrEl"></div>
    </div>
  </div>

  <div class="split-card se-new-card" id="voNewCard">
    <span class="sc-label">Add option</span>
    <div class="se-new-row" style="grid-template-columns:1fr">
      <input class="split-in" type="text" placeholder="e.g. Gwangjang Market" id="voNewText" />
    </div>
    <button class="sc-add-expense-btn" id="voAddOption" type="button">+ Add option</button>
  </div>

  <div class="split-card">
    <div class="sc-head">
      <span class="sc-label">Options</span>
      <button class="sc-add-btn" id="voReset" type="button">↺ Reset votes</button>
    </div>
    <div class="sc-body" id="voList">
      <p class="split-empty">Add a couple of options to start voting.</p>
    </div>
  </div>

</div>

<!-- Behavior lives in the src/features/voting silo (imported in the GuideLayout bundle).
     Markup only here — the base64url vote-link codec is tested in the silo's model/. -->

