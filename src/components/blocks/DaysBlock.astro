---
// Day-by-day itinerary — the heart of the Plan view. Renders:
//   1. A numbered day-scrubber (color-block chips) — sticky, scroll-synced +
//      click-to-jump via day-rail.js.
//   2. The day cards, full width (single column).
//   3. Per-day numbered stop lists from the additive `waypoints` field — the
//      on-the-go itinerary ladder (time in data face, name, note).
import TransitLinks from "../TransitLinks.astro";
const { sec, keyPrefix = "dy", learnings = null, country } = Astro.props;
const days: any[] = sec.items || [];
const two = (n: number) => String(n + 1).padStart(2, "0");
// Curated post-mortem for THIS day, matched by date. Only days the maker actually
// reflected on get a Plan ⇄ Actual toggle — the rest render exactly as before.
const actualFor = (date: string) =>
  (learnings?.days ?? []).find((d: any) => d.date === date) ?? null;
---
{days.length > 0 && (
  <button class="story-play" type="button" data-story-open aria-haspopup="dialog">
    <span class="story-play-ico" aria-hidden="true">▶</span>
    <span class="story-play-txt">Play the trip</span>
    <span class="story-play-sub">{days.length} days · swipe through</span>
  </button>
)}
<nav class="day-scrub" id="dayScrub" aria-label="Jump to a day">
  {days.map((d: any, di: number) => (
    <button class="dchip" type="button" data-day-jump={di} aria-label={`Jump to ${d.date}`}>
      <span class="dchip-num">{two(di)}</span>
      <span class="dchip-date">{d.date}</span>
    </button>
  ))}
</nav>

<div class="planner">
  <div class="planner-days">
    {days.map((d: any, di: number) => (
      <div class="day" data-day={di} id={`day-${di}`}>
        <div class="d"><span class="day-num">{two(di)}</span>{d.date}</div>
        <div class="b">
          <strong>{d.title}</strong>
          {actualFor(d.date) && (
            <div class="day-flip" role="group" aria-label="Plan or what actually happened">
              <button class="day-flip-btn on" type="button" data-flip="plan" aria-pressed="true">Plan</button>
              <button class="day-flip-btn" type="button" data-flip="actual" aria-pressed="false">Actually</button>
            </div>
          )}
          {actualFor(d.date) && (
            <div class="day-actual" hidden>
              {actualFor(d.date).actually && <p class="learn-actually"><Fragment set:html={actualFor(d.date).actually} /></p>}
              {(actualFor(d.date).skipped ?? []).length > 0 && (
                <>
                  <p class="learn-sub">Skipped</p>
                  <ul class="learn-skips">
                    {actualFor(d.date).skipped.map((s: any) => (
                      <li>
                        <span class="learn-skip-stop">✗ {s.stop}</span>
                        {s.reason && <span class="learn-skip-why">{s.reason}</span>}
                      </li>
                    ))}
                  </ul>
                </>
              )}
            </div>
          )}
          {d.tldr && <p class="day-tldr">{d.tldr}</p>}
          {d.checklist && d.checklist.length > 0 && (
            <span class="day-kitcount" hidden aria-live="polite"></span>
          )}
          <span class="day-sun" hidden></span>
          {d.pace && <div class="pace">⏱ {d.pace}</div>}
          {d.waypoints && d.waypoints.length > 0 && (
            <ol class="stops" aria-label="Stops this day">
              {d.waypoints.map((w: any, wi: number) => (
                <li class="stop">
                  <span class="stop-num">{String(wi + 1).padStart(2, "0")}</span>
                  <span class="stop-main">
                    <span class="stop-name">{w.name}</span>
                    {w.note && <span class="stop-note">{w.note}</span>}
                    {Number.isFinite(w.lat) && Number.isFinite(w.lng) && (
                      <TransitLinks lat={w.lat} lng={w.lng} name={w.name} country={country} />
                    )}
                  </span>
                  {w.time && <span class="stop-time">{w.time}</span>}
                </li>
              ))}
            </ol>
          )}
          {d.note && <span class="lsnote">🌿 <Fragment set:html={d.note} /></span>}
          {d.body && <div><Fragment set:html={d.body} /></div>}
          {d.fit  && <div class="fit">Fit: <Fragment set:html={d.fit} /></div>}
          {d.checklist && d.checklist.length > 0 && (
            <div class="daykit">
              <span class="kit-label">Day kit</span>
              {d.checklist.map((i: string, j: number) => (
                <label class="check"><input type="checkbox" data-pkey={`${keyPrefix}-d${di}-${j}`} /><span class="check-txt"><Fragment set:html={i} /></span></label>
              ))}
            </div>
          )}
        </div>
      </div>
    ))}
  </div>
</div>
