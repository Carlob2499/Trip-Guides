---
import { pinSlug } from "../../lib/map-pins";
import TransitLinks from "../TransitLinks.astro";
const { sec, country } = Astro.props;

// Wikimedia's Special:FilePath already supports ?width= thumbnailing —
// use that directly instead of pulling the image through Astro's optimizer.
// This avoids build-time HTTP fetches (and Wikimedia 429 rate-limits) while
// still giving the browser a proper responsive srcset.
const commonsSrc  = (f: string, w = 800) =>
  `https://commons.wikimedia.org/wiki/Special:FilePath/${encodeURIComponent(f)}?width=${w}`;
const commonsPage = (f: string) =>
  `https://commons.wikimedia.org/wiki/File:${encodeURIComponent(f)}`;
---
{(sec.items || []).map((it: any) => (
  <article class={`card sight ${it.img ? "sight--photo" : "sight--text"}`} id={it.map ? `sight-${pinSlug(it.name)}` : undefined}>
    {it.img ? (
      /* Photo-forward: the image is the card hero with an overlaid caption
         (kicker + name), a legibility gradient, and a hover zoom. */
      <figure class="sight-media">
        <img class="cardimg" loading="lazy" decoding="async" alt={it.img.alt || it.name || ""}
          src={commonsSrc(it.img.file, 800)}
          srcset={`${commonsSrc(it.img.file, 480)} 480w, ${commonsSrc(it.img.file, 800)} 800w, ${commonsSrc(it.img.file, 1200)} 1200w`}
          sizes="(max-width:899px) 100vw, 420px"
          onerror="this.closest('.sight-media').classList.add('media-fail')" />
        <span class="sight-media-grad" aria-hidden="true"></span>
        <figcaption class="sight-media-cap">
          {it.kicker && <span class="tag tag--onphoto">{it.kicker}</span>}
          <h4 class="sight-name sight-name--onphoto">{it.name}</h4>
        </figcaption>
        <a class="imgcredit imgcredit--onphoto" href={commonsPage(it.img.file)} target="_blank" rel="noopener" aria-label="Photo source on Wikimedia Commons">Wikimedia Commons ↗</a>
      </figure>
    ) : (
      <div class="sight-head">
        {it.kicker && <span class="tag">{it.kicker}</span>}
        <h4 class="sight-name">{it.name}</h4>
      </div>
    )}
    <div class="sight-body">
      <p><Fragment set:html={it.body || ""} /></p>
      {it.map && (
        <TransitLinks lat={it.map.lat} lng={it.map.lng} name={it.name} country={country} />
      )}
    </div>
  </article>
))}
