---
// Area map for a guide section. Default: a lightweight OpenStreetMap embed
// (no map library, works with JS on or off). If a Google Maps key is set at
// build (PUBLIC_GMAPS_KEY → tgConfig), gmaps-render.js upgrades this mount to
// an interactive Google map with pins; without a key, the OSM embed stays.
const { sec, pins } = Astro.props;
const bbox = (c: any, span?: number) => {
  const s = span || 0.05;
  return [c.lng - s, c.lat - s * 0.6, c.lng + s, c.lat + s * 0.6].join("%2C");
};
import { jsonEmbed } from "../../lib/json-embed";
const payload = jsonEmbed({
  center: { lat: sec.center.lat, lng: sec.center.lng },
  span: sec.span ?? null,
  pins: pins ?? [],
});
---
<div class="itin-map" data-itin-map>
  <script type="application/json" data-map-data set:html={payload} />
  <iframe class="osmmap" loading="lazy" title="Area map" allowfullscreen
    src={`https://www.openstreetmap.org/export/embed.html?bbox=${bbox(sec.center, sec.span)}&layer=mapnik&marker=${sec.center.lat}%2C${sec.center.lng}`}>
  </iframe>
</div>
<p class="note">⚠ The map needs an internet connection — the written transit steps in this section work offline.</p>
