---
// Trip kit — a tool tab (like Budget/Vote/Reminders) housing focused, on-the-ground
// helpers (docs/FEATURES.md #5 arrival autopilot, #6 phrase cards, #7 entry requirements).
// Server-rendered from data the guide already carries; no new client JS needed for
// content (checkbox persistence is the existing global guide-ui.js scan — see
// model/arrival.ts header). Cards render in trip-chronological order: entry
// requirements (settle before you book) → arrival autopilot (the day you land) →
// phrase cards (useful any day) — each independently optional, never fabricated.
import TransitLinks from "./TransitLinks.astro";
import { deriveArrivalPlan } from "../features/trip-kit/index.js";
import "../features/trip-kit/styles.css";

interface Props {
  storeKey: string; country: string; days: any[];
  phrases?: { lang?: string; items: any[] } | null;
  entry?: any[] | null;
}
const { storeKey, country, days, phrases = null, entry = null } = Astro.props;
const arrival = deriveArrivalPlan(days);
const hasPhrases = !!(phrases && Array.isArray(phrases.items) && phrases.items.length);
const hasEntry = !!(entry && entry.length);
---
<div class="tk-wrap" id="tripKit" role="tabpanel" aria-labelledby="gtab-kit" data-sk={storeKey} hidden>
  <div class="tk-head">
    <p class="tk-eyebrow">Trip kit</p>
    <h2 class="tk-title">On-the-ground tools</h2>
    <p class="tk-desc">Focused helpers for specific moments of the trip — starting with the moment you land.</p>
  </div>

  {hasEntry && (
    <section class="tk-card" aria-labelledby="tk-entry-h">
      <p class="tk-card-eyebrow">🛂 Entry requirements</p>
      <h3 class="tk-card-title" id="tk-entry-h">Before you book</h3>
      {entry!.length > 1 && (
        <label class="tk-entry-picker">
          <span class="tk-entry-picker-label">Your passport</span>
          <select class="tk-entry-select" id="tkEntrySelect">
            {entry!.map((e: any, i: number) => (
              <option value={String(i)}>{e.homeCountry}</option>
            ))}
          </select>
        </label>
      )}
      <div class="tk-entry-rows">
        {entry!.map((e: any, i: number) => (
          <div class="tk-entry-row" data-entry-idx={String(i)} hidden={entry!.length > 1 && i !== 0}>
            <p class="tk-entry-country">{e.homeCountry}</p>
            <p class="tk-entry-visa">{e.visa}</p>
            {e.passportValidity && <p class="tk-entry-passport">Passport: {e.passportValidity}</p>}
            {e.note && <p class="tk-entry-note">{e.note}</p>}
            <p class="tk-entry-source">
              Checked {e.verified_on} · <a href={e.source_url} target="_blank" rel="noopener">official source ↗</a>
            </p>
          </div>
        ))}
      </div>
    </section>
  )}

  {arrival && (
    <section class="tk-card" aria-labelledby="tk-arrival-h">
      <p class="tk-card-eyebrow">✈ Arrival autopilot · {arrival.date}</p>
      <h3 class="tk-card-title" id="tk-arrival-h">{arrival.title}</h3>
      {arrival.tldr && <p class="tk-card-tldr">{arrival.tldr}</p>}

      {arrival.steps.length > 0 && (
        <ol class="tk-steps">
          {arrival.steps.map((s, i) => (
            <li class="tk-step">
              <span class="tk-step-n">{String(i + 1).padStart(2, "0")}</span>
              <span class="tk-step-main">
                <span class="tk-step-name">{s.name}</span>
                {s.note && <span class="tk-step-note">{s.note}</span>}
                {s.lat != null && s.lng != null && (
                  <TransitLinks lat={s.lat} lng={s.lng} name={s.name} country={country} />
                )}
              </span>
              {s.time && <span class="tk-step-time">{s.time}</span>}
            </li>
          ))}
        </ol>
      )}

      {arrival.checklist.length > 0 && (
        <div class="tk-checklist">
          <p class="tk-checklist-label">Before you go</p>
          {arrival.checklist.map((item, j) => (
            <label class="check"><input type="checkbox" data-pkey={`tk-arr-${j}`} /><span class="check-txt">{item}</span></label>
          ))}
        </div>
      )}

      {arrival.fit && <p class="tk-fit">🧳 {arrival.fit}</p>}
    </section>
  )}

  {hasPhrases && (
    <section class="tk-card" aria-labelledby="tk-phrases-h">
      <p class="tk-card-eyebrow">💬 Phrase cards</p>
      <h3 class="tk-card-title" id="tk-phrases-h">Show this to someone</h3>
      <p class="tk-card-tldr">Verified phrases in big, native-script type — point + show the screen, or tap to hear it spoken aloud.</p>
      <div class="tk-phrases">
        {phrases!.items.map((p: any, i: number) => (
          <article class="tk-phrase">
            <p class="tk-phrase-situation">{p.situation}</p>
            <p class="tk-phrase-native" lang={phrases!.lang || undefined}>{p.native}</p>
            {p.romanization && <p class="tk-phrase-roman">{p.romanization}</p>}
            {p.note && <p class="tk-phrase-note">{p.note}</p>}
            {phrases!.lang && (
              <button class="tk-speak" type="button" data-speak-text={p.native} data-speak-lang={phrases!.lang} aria-label={`Speak: ${p.situation}`}>
                🔊 <span>Speak</span>
              </button>
            )}
          </article>
        ))}
      </div>
    </section>
  )}

  {!arrival && !hasPhrases && !hasEntry && (
    <p class="tk-empty">Nothing here yet — this tab lights up as the guide's itinerary, phrase cards, and entry requirements are filled in.</p>
  )}
</div>

<script>
  import { initSpeak, initEntrySelect } from "../features/trip-kit/index.js";
  const initAll = () => { initSpeak(); initEntrySelect(); };
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initAll, { once: true });
  } else {
    initAll();
  }
</script>
