{
  "rules": {
    ".read": false,
    ".write": false,
    "trips": {
      "$code": {
        ".read": "auth != null",
        ".write": "auth != null && $code.length >= 16 && $code.length <= 40",
        ".validate": "$code.length >= 16 && $code.length <= 40",
        "members": {
          "$mid": {
            ".validate": "$mid.matches(/^[A-Za-z0-9_-]{1,40}$/) && newData.hasChildren(['name'])",
            "name": { ".validate": "newData.isString() && newData.val().length <= 60" },
            "payment": { ".validate": "newData.isString() && newData.val().length <= 80" },
            "order": { ".validate": "newData.isNumber()" },
            "createdBy": { ".validate": "newData.isString() && newData.val().length <= 64" },
            "createdAt": { ".validate": "newData.isNumber()" },
            "$other": { ".validate": false }
          }
        },
        "expenses": {
          "$eid": {
            ".validate": "$eid.matches(/^[A-Za-z0-9_-]{1,40}$/)",
            "paidBy": { ".validate": "newData.isString() && newData.val().length <= 64" },
            "desc": { ".validate": "newData.isString() && newData.val().length <= 120" },
            "amount": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 100000000" },
            "order": { ".validate": "newData.isNumber()" },
            "createdBy": { ".validate": "newData.isString() && newData.val().length <= 64" },
            "createdAt": { ".validate": "newData.isNumber()" },
            "split": {
              "$pid": { ".validate": "$pid.matches(/^[A-Za-z0-9_-]{1,40}$/) && newData.isNumber() && newData.val() >= 0 && newData.val() <= 100000000" }
            },
            "participants": {
              "$i": { ".validate": "newData.isString() && newData.val().length <= 40" }
            },
            "$other": { ".validate": false }
          }
        },
        "meta": {
          "customSplit": { ".validate": "newData.isBoolean()" },
          "$other": { ".validate": false }
        },
        "feedback": {
          "$fid": {
            ".validate": "$fid.matches(/^[A-Za-z0-9_-]{1,40}$/) && newData.hasChild('createdBy')",
            "$field": { ".validate": "!newData.isString() || newData.val().length <= 4000" }
          }
        },
        "reminders": {
          "$rid": {
            ".validate": "$rid.matches(/^[A-Za-z0-9_-]{1,40}$/) && newData.hasChild('createdBy')",
            "$field": { ".validate": "!newData.isString() || newData.val().length <= 2000" }
          }
        },
        "$other": { ".validate": false }
      }
    },
    "errors": {
      ".read": false,
      ".write": "auth != null",
      "$eid": {
        ".validate": "$eid.matches(/^[A-Za-z0-9_-]+$/)",
        "guide": { ".validate": "newData.isString() && newData.val().length <= 60" },
        "feature": { ".validate": "newData.isString() && newData.val().length <= 60" },
        "message": { ".validate": "newData.isString() && newData.val().length <= 500" },
        "ua": { ".validate": "newData.isString() && newData.val().length <= 200" },
        "at": { ".validate": "newData.isNumber()" },
        "$other": { ".validate": false }
      }
    },
    "telemetry": {
      ".read": true,
      ".write": "auth != null",
      "$guide": {
        ".validate": "$guide.matches(/^[a-z0-9_-]{1,60}$/)",
        "tabs": {
          "$name": { ".validate": "$name.matches(/^[a-z0-9_-]{1,40}$/) && newData.isNumber() && newData.val() >= 0" }
        },
        "tools": {
          "$name": { ".validate": "$name.matches(/^[a-z0-9_-]{1,40}$/) && newData.isNumber() && newData.val() >= 0" }
        },
        "$other": { ".validate": false }
      }
    }
  }
}
