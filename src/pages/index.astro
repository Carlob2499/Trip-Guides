---
import { getCollection } from "astro:content";
import PwaHead from "../components/PwaHead.astro";
import { accentFor } from "../lib/themes";
import { flattenSections } from "../lib/exports";
import "../styles/hub.css";

const guides = (await getCollection("guides")).sort((a, b) =>
  a.data.title.localeCompare(b.data.title)
);

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

// Trip-date math below intentionally uses LOCAL time (not the UTC parsing in
// lib/holidays.ts) — this badge is "N days away" relative to the visitor's own
// clock, same as the countdown pill in GuideLayout.astro.
const MONTH_MAP: Record<string, number> = {
  Jan:0,Feb:1,Mar:2,Apr:3,May:4,Jun:5,Jul:6,Aug:7,Sep:8,Oct:9,Nov:10,Dec:11
};

function parseTripDate(dateStr: string | undefined): Date | null {
  if (!dateStr) return null;
  const parts = dateStr.split(/\s+/);
  const mon = parts[1]; const d = parseInt(parts[2], 10);
  if (!mon || isNaN(d) || MONTH_MAP[mon] == null) return null;
  const now = new Date();
  const dt  = new Date(now.getFullYear(), MONTH_MAP[mon], d);
  if (dt < now && (now.getTime() - dt.getTime()) > 180 * 86400000) dt.setFullYear(now.getFullYear() + 1);
  return dt;
}

const now = new Date();
const guideExtras = guides.map(g => {
  const flat = flattenSections(g.data.sections as any[] || []);
  const allDays = flat.filter((s: any) => s.type === "days");
  const allItems = allDays.flatMap((s: any) => s.items || []);
  const firstDate = parseTripDate(allItems[0]?.date);
  const lastDate  = parseTripDate(allItems[allItems.length - 1]?.date);
  const dayCount  = allItems.length;
  let badge = "";
  if (firstDate) {
    const diff = Math.round((firstDate.getTime() - now.getTime()) / 86400000);
    if (diff > 1)       badge = diff + " days away";
    else if (diff === 1) badge = "Tomorrow!";
    else if (diff === 0) badge = "Today!";
    else if (diff >= -7) badge = "Now!";
    else if (lastDate && lastDate > now) badge = "In progress";
  }
  return { dayCount, badge };
});
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Waypoint — Travel Guides</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@1,9..144,300..700&family=Space+Grotesk:wght@500;600;700&family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />
    <PwaHead />
    <!-- Dark-mode init — runs before paint to avoid flash -->
    <script is:inline>
      (function () {
        var s = localStorage.getItem("tg-theme");
        var preferDark = window.matchMedia && window.matchMedia("(prefers-color-scheme:dark)").matches;
        if (s === "dark" || (s === null && preferDark)) {
          document.documentElement.setAttribute("data-theme", "dark");
        } else if (s === "light") {
          document.documentElement.setAttribute("data-theme", "light");
        }
      })();
    </script>
  </head>
  <body>
    <header class="hub-masthead">
      <div class="hub-topbar">
        <button id="btnDark" class="topbar-btn" aria-label="Switch to dark mode" title="Switch to dark mode">◑</button>
      </div>
      <div class="hub-rule" aria-hidden="true"></div>
      <p class="eyebrow">Travel Guides</p>
      <h1>Waypoint</h1>
      <p class="dek">Curated, fact-checked guides — built to be calm to read and easy to follow on the move.</p>
      <p class="hub-count">{guides.length} destinations</p>
    </header>

    <main class="hub">
      <div class="hub-grid">
        {guides.map((g, i) => {
          const ex = guideExtras[i];
          return (
          <a class="hubcard" href={`${base}/guides/${g.id}/`} style={`--accent:${accentFor(g.data.country)}`}>
            <span class="hubcard-bar" aria-hidden="true"></span>
            <span class="hubcard-body">
              <span class="hubcard-top">
                <span class="hubcard-country">{g.data.country}</span>
                {ex.badge && <span class="hubcard-badge">{ex.badge}</span>}
              </span>
              <span class="hubcard-title">{g.data.title}</span>
              {g.data.dek && <span class="hubcard-dek">{g.data.dek}</span>}
              <span class="hubcard-meta">
                {ex.dayCount > 0 && <span class="hubcard-days">{ex.dayCount} days</span>}
              </span>
              <span class="hubcard-go">Open guide →</span>
            </span>
          </a>
          );
        })}
      </div>
    </main>

    <footer class="hub-foot">Waypoint — every fact checked, every route tested.</footer>

    <script is:inline>
      (function () {
        var darkBtn = document.getElementById("btnDark");
        function syncDark() {
          var dark = document.documentElement.getAttribute("data-theme") === "dark";
          if (!darkBtn) return;
          darkBtn.textContent = dark ? "☀" : "◑";
          darkBtn.setAttribute("aria-label", dark ? "Switch to light mode" : "Switch to dark mode");
          darkBtn.title = dark ? "Switch to light mode" : "Switch to dark mode";
        }
        syncDark();
        if (darkBtn) {
          darkBtn.addEventListener("click", function () {
            var dark = document.documentElement.getAttribute("data-theme") === "dark";
            var next = dark ? "light" : "dark";
            document.documentElement.setAttribute("data-theme", next);
            try { localStorage.setItem("tg-theme", next); } catch (e) {}
            syncDark();
          });
        }
      })();
    </script>
  </body>
</html>
