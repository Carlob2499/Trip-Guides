---
import { getCollection } from "astro:content";
import { accentFor } from "../lib/themes";
import "../styles/hub.css";

// The home page builds itself from whatever guides exist — no hand-kept list.
const guides = (await getCollection("guides")).sort((a, b) =>
  a.data.title.localeCompare(b.data.title)
);
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Trip Guides</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <header class="hub-masthead">
      <p class="eyebrow">Field Guides</p>
      <h1>Trip Guides</h1>
      <p class="dek">Curated, fact-checked travel guides — built to be calm to read and easy to follow on the move.</p>
    </header>

    <main class="hub">
      <div class="hub-grid">
        {guides.map((g) => (
          <a class="hubcard" href={`/guides/${g.id}/`} style={`--accent:${accentFor(g.data.country)}`}>
            <span class="hubcard-top">
              <span class="hubcard-dot"></span>
              <span class="hubcard-country">{g.data.country}</span>
            </span>
            <span class="hubcard-title">{g.data.title}</span>
            {g.data.dek && <span class="hubcard-dek">{g.data.dek}</span>}
            <span class="hubcard-go">Open guide →</span>
          </a>
        ))}
      </div>
    </main>

    <footer class="hub-foot">Built from the reusable trip-guide template.</footer>
  </body>
</html>
