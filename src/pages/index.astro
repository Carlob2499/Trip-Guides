---
import { getCollection } from "astro:content";
import PwaHead from "../components/PwaHead.astro";
// Same accent resolution as the guide pages + OG (uniform across surfaces):
// explicit theme > extracted cover palette > country accent (src/lib/palettes.ts).
import { accentForGuide, paletteAccentsForGuide } from "../lib/palettes";
import { generateContourLayer } from "../lib/contours";
import { computeGuideStats } from "../lib/guide-stats";
import { tripWindow, localISODate } from "../lib/trip-dates";
import { continentFor, CONTINENT_ORDER } from "../data/countries.mjs";
import { flattenSections } from "../features/exports/index";
// Self-hosted variable fonts (bundled, base-path-safe, offline-correct) — no CDN.
import "@fontsource-variable/bricolage-grotesque";
import "@fontsource-variable/literata";
import "@fontsource-variable/spline-sans-mono";
import "../styles/base.css";
import "../styles/hub.css";
import "../styles/hub-cards.css";
import "../styles/wizard.css";
import "../styles/transitions.css";
import "../styles/scroll-motion.css";
import "../styles/hub-motion.css";

const guides = (await getCollection("guides")).sort((a, b) =>
  a.data.title.localeCompare(b.data.title)
);

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
// Repo the "Make a new guide" button files its GitHub issue against.
const REPO = "Carlob2499/Trip-Guides";

// Trip-date math below uses the SAME shared resolver as the guide page's own countdown
// (src/lib/trip-dates.ts) — this badge is "N days away" relative to the visitor's own
// clock, and must read the same on the hub as on GuideLayout.astro's countdown pill
// (R1/R2): two hand-rolled copies of this logic previously drifted (time-of-day vs
// midnight math), so there is now exactly one implementation, imported, not duplicated.
const now = new Date();
const guideExtras = guides.map(g => {
  const flat = flattenSections(g.data.sections as any[] || []);
  const allDays = flat.filter((s: any) => s.type === "days");
  const allItems = allDays.flatMap((s: any) => s.items || []);
  const firstDateStr = allItems[0]?.date;
  const lastDateStr  = allItems[allItems.length - 1]?.date;
  const win = tripWindow(firstDateStr, lastDateStr, now);
  const firstDate = win.start;
  const lastDate  = win.end;
  const dayCount  = allItems.length;
  let badge = "";
  if (win.hasDates) {
    const diff = win.daysUntilStart;
    if (diff > 1)          badge = diff + " days away";
    else if (diff === 1)   badge = "Tomorrow!";
    else if (diff === 0)   badge = "Today!";
    else if (win.isOngoing) badge = "Now!"; // today falls within [start, end] inclusive
    // else: trip is past — no badge (a finished trip gets the static heroWhen treatment below)
  }
  // Hero/filter extras — all derivable at build from data the guide already has.
  const mapSec  = flat.find((s: any) => s.type === "map" && typeof s.center?.lat === "number");
  const sight   = flat.filter((s: any) => s.type === "sights").flatMap((s: any) => s.items || []).find((it: any) => it?.img?.file);
  const month   = firstDateStr?.split(/\s+/)[1] || "";
  // The card/hero cover: the guide's own `cover` art when set, else its first sight photo
  // (docs/MOTION.md). Same image the guide masthead uses — that's what makes them morph.
  const cover = (g.data as any).cover;
  const coverImg = cover?.file
    ? { file: cover.file, alt: cover.alt || "", focal: cover.focal || null }
    : (sight ? { file: sight.img.file, alt: sight.img.alt || sight.name, focal: null } : null);
  return {
    dayCount, badge, firstDate, lastDate, month,
    // R2: LOCAL calendar components, never `.toISOString()` (UTC conversion drifts the
    // calendar day for any negative UTC offset) — this string is compared against
    // hub.js's own client-side "today" string, so both sides must build it the same way.
    startISO: firstDate ? localISODate(firstDate) : "",
    mapCenter: mapSec ? { lat: mapSec.center.lat, lng: mapSec.center.lng } : null,
    heroImg: coverImg,
  };
});

// Only finished, verified guides appear on the hub. A generated draft lives at
// its own URL until it graduates (draft:false) — the hub never shows scaffolds.
const withExtras = guides.map((g, i) => ({ g, ex: guideExtras[i] }));
const curated = withExtras.filter(x => !x.g.data.draft);

// Next-trip hero: the curated guide whose trip starts soonest in the future
// (or is in progress right now).
const upcoming = curated
  .filter(x => x.ex.firstDate && (x.ex.firstDate >= now || (x.ex.lastDate && x.ex.lastDate >= now)))
  .sort((a, b) => a.ex.firstDate!.getTime() - b.ex.firstDate!.getTime());
// Retrospective fallback: between trips there IS no next trip, and the hub used to drop the
// hero entirely — losing its whole first impression (and the site's best photo) exactly when
// the guides are at their most proven. So feature the most recently FINISHED trip instead,
// labelled honestly as past. Every guide is eventually past; the hero shouldn't expire.
const finished = curated
  .filter(x => x.ex.lastDate && x.ex.lastDate < now)
  .sort((a, b) => b.ex.lastDate!.getTime() - a.ex.lastDate!.getTime());
const hero = upcoming[0] ?? finished[0] ?? null;
const heroIsPast = upcoming.length === 0 && finished.length > 0;
// A finished trip gets a static month/year, never the live countdown — hub.js would render
// any past start date as "In progress", which would be a lie about a trip that's over.
const heroWhen = heroIsPast && hero?.ex.lastDate
  ? hero.ex.lastDate.toLocaleDateString("en-US", { month: "short", year: "numeric" })
  : "";
// The hero IS that guide's entry on the hub — don't render it twice. The grid
// The grid is the COMPLETE index — every curated guide, including the one featured in
// the hero. Excluding the hero used to make "All" quietly mean "all but one", and left a
// filtered view looking like a guide had vanished. The hero is an editorial band ABOVE the
// filter; the grid below it is the list. The hero's own card is marked (not hidden) so it
// reads as the same trip, not a second one.
const gridGuides = curated;
const heroId = hero?.g.id ?? null;
const heroSrc = hero?.ex.heroImg
  ? `https://commons.wikimedia.org/wiki/Special:FilePath/${encodeURIComponent(hero.ex.heroImg.file)}?width=1400`
  : null;
// Card cover thumbnails — same Commons thumbnailing at grid width.
const coverSrc = (img: { file: string } | null) =>
  img ? `https://commons.wikimedia.org/wiki/Special:FilePath/${encodeURIComponent(img.file)}?width=640` : null;

// Filter chips: by CONTINENT, not country. With a handful of guides a country chip just
// restates the card beneath it; continent is the axis you actually browse by as the library
// grows. Only continents that have a guide get a chip, in CONTINENT_ORDER (stable — chips
// don't reshuffle alphabetically when a new trip lands).
const gridContinents = new Set(
  gridGuides.map(x => continentFor(x.g.data.country)).filter(Boolean) as string[]
);
const continents = CONTINENT_ORDER.filter(c => gridContinents.has(c));

// Overture (V2, docs/PLAN_VISUAL_OVERHAUL.md) — real, build-time-counted stats for the intro's
// stats beat (never hand-typed numbers; recomputed every build) + three deterministic contour
// layers for its parallax backdrop. Fixed seeds ⇒ identical rings every build.
const stats = computeGuideStats(guides.map((g) => g.data));
const contourLayers = [
  generateContourLayer({ seed: 7, rings: 9, cx: 260, cy: 320 }),
  generateContourLayer({ seed: 23, rings: 8, cx: 780, cy: 640 }),
  generateContourLayer({ seed: 41, rings: 5, cx: 540, cy: 180 }),
];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Waypoint — Travel Guides</title>
    <PwaHead />
    <!-- Dark-mode init — runs before paint to avoid flash -->
    <script is:inline>
      (function () {
        var s = localStorage.getItem("tg-theme");
        var preferDark = window.matchMedia && window.matchMedia("(prefers-color-scheme:dark)").matches;
        if (s === "dark" || (s === null && preferDark)) {
          document.documentElement.setAttribute("data-theme", "dark");
        } else if (s === "light") {
          document.documentElement.setAttribute("data-theme", "light");
        }
      })();
    </script>
    <!-- Overture state — set before paint so a return visitor never flashes the full intro
         before it collapses to the compact hero (mirrors the theme init above). -->
    <script is:inline>
      (function () {
        try {
          var seen = localStorage.getItem("tg-overture-seen");
          document.documentElement.setAttribute("data-overture", seen ? "compact" : "full");
        } catch (e) {
          document.documentElement.setAttribute("data-overture", "full");
        }
      })();
    </script>
  </head>
  <body data-base={base}>
    <a class="skip-link" href="#hubGrid">Skip to guides</a>
    <!-- THE OVERTURE (V2) — the hub masthead as a full-viewport intro that hands off to the
         guide grid via src/scripts/overture.js. Base markup is fully visible with no JS; the
         script only adds motion. #btnDark / #btnNewGuide keep their IDs for the inline scripts. -->
    <header class="overture" id="overture">
      <div class="ov-contours" aria-hidden="true">
        {contourLayers.map((layer, i) => (
          <svg data-ov-contour={i} viewBox={`0 0 ${layer.viewBox} ${layer.viewBox}`} preserveAspectRatio="xMidYMid slice">
            {layer.rings.map((points) => <polyline points={points} />)}
          </svg>
        ))}
      </div>

      <div class="ov-bar">
        <span class="ov-wordmark">Waypoint</span>
        <div class="ov-bar-actions">
          <button id="btnNewGuide" class="ov-pill ov-pill-solid" type="button">＋ New guide</button>
          <button id="btnDark" class="ov-pill ov-pill-icon" aria-label="Switch to dark mode" title="Switch to dark mode">◑</button>
        </div>
      </div>

      <div class="ov-inner">
        {/* U10: the guide count used to render here too ("· N destinations") AND as its
            own real number in the stats beat below ("Trips, fully planned") — the same
            fact shown twice as if it were two different things. The stats beat is the
            authoritative count now; the eyebrow states what the guides ARE, not how many. */}
        <p class="ov-eyebrow">Verified travel guides</p>
        <h1 class="ov-head">
          <span class="ov-line">Every fact checked.</span>
          <span class="ov-line ov-line-accent">Every trip yours.</span>
        </h1>
        <p class="ov-sub">
          {/* The {" "} is load-bearing, not decoration: Astro 7 compiles templates with JSX
              whitespace rules, which STRIP the newline between </b> and the next text node. Without
              it this above-the-fold line renders "primary source— and stamped". */}
          Never autogenerated. Every price, hour, and door checked against a <b>primary source</b>{" "}
          — and stamped with the date we checked it.
        </p>
      </div>

      <svg class="ov-route" viewBox="0 0 120 400" preserveAspectRatio="none" aria-hidden="true">
        <path class="ov-route-path" d="M60 0 C 60 130, 24 210, 60 320 S 60 384 60 400" />
        <circle class="ov-route-dot" r="5" cx="60" cy="0" />
      </svg>

      <a class="ov-cue" href="#hubStart">
        <span class="ov-cue-pin" aria-hidden="true"></span>Follow the route
      </a>
    </header>

    <section class="stats-beat" aria-label="What's inside these guides">
      <div class="stats-beat-in">
        <div class="stat"><div class="stat-n" data-count={stats.guideCount}>{stats.guideCount}</div><div class="stat-l">Trips, fully planned</div></div>
        <div class="stat"><div class="stat-n is-accent" data-count={stats.verifiedFactCount}>{stats.verifiedFactCount}</div><div class="stat-l">Facts traced to a source</div></div>
        <div class="stat"><div class="stat-n" data-count={stats.sourceCount}>{stats.sourceCount}</div><div class="stat-l">Distinct primary sources</div></div>
      </div>
      <p class="stats-note">Real numbers, counted from the guides themselves — the same honesty rule the guides live by.</p>
    </section>

    <main class="hub" id="hubStart">
      {hero && (
        <a
          class="hub-hero"
          href={`${base}/guides/${hero.g.id}/`}
          style={`--accent:${accentForGuide(hero.g.id, hero.g.data.theme, hero.g.data.country)}`}
          data-hero-start={heroIsPast ? undefined : hero.ex.startISO}
          data-hero-lat={heroIsPast ? undefined : hero.ex.mapCenter?.lat}
          data-hero-lng={heroIsPast ? undefined : hero.ex.mapCenter?.lng}
        >
          {heroSrc && (
            <img class="hub-hero-img" src={heroSrc} alt={hero.ex.heroImg!.alt} loading="eager" fetchpriority="high"
                 style={`view-transition-name:cover-${hero.g.id}`} />
          )}
          <span class="hub-hero-scrim" aria-hidden="true"></span>
          <span class="hub-hero-body">
            <span class="hub-hero-eyebrow">{heroIsPast ? "Last trip" : "Next trip"}{hero.g.data.country !== hero.g.data.title ? ` · ${hero.g.data.country}` : ""}</span>
            <span class="hub-hero-title">{hero.g.data.title}</span>
            <span class="hub-hero-meta">
              {heroIsPast
                ? <span class="hub-hero-count hub-hero-past">{heroWhen}</span>
                : <span class="hub-hero-count" data-hero-countdown>{hero.ex.badge}</span>}
              {/* Today's weather at the destination is only useful for a trip you're about
                  to take — a finished one gets no pill. */}
              {!heroIsPast && <span class="hub-hero-wx" data-hero-wx hidden></span>}
              {hero.ex.dayCount > 0 && <span class="hub-hero-days">{hero.ex.dayCount} days {heroIsPast ? "travelled" : "planned"}</span>}
            </span>
            <span class="hub-hero-cta">{heroIsPast ? "See how it went →" : "Open the guide →"}</span>
          </span>
        </a>
      )}

      <div class="hub-filter" role="search">
        <input class="hub-search" id="hubSearch" type="search" placeholder="Search guides…" aria-label="Search guides" autocomplete="off" />
        <div class="hub-chips" id="hubChips" role="group" aria-label="Filter by continent">
          <button class="hub-chip hub-chip-active" type="button" data-filter="">All trips</button>
          {continents.map((c) => (
            <button class="hub-chip" type="button" data-filter={c}>{c}</button>
          ))}
        </div>
      </div>

      <div class="hub-grid" id="hubGrid">
        {gridGuides.map(({ g, ex }) => {
          // The full 3-stop palette, not just --accent — unused until V3 (Atlas card tinting,
          // docs/PLAN_VISUAL_OVERHAUL.md) wires --accent2/--accent-raw into real CSS. Set here
          // now so V3 is a pure-CSS session, no markup change required.
          const pal = paletteAccentsForGuide(g.id, g.data.theme, g.data.country);
          return (
          <a
            class:list={["hubcard", { "hubcard-featured": g.id === heroId }]}
            href={`${base}/guides/${g.id}/`}
            style={`--accent:${pal.primary};--accent2:${pal.secondary};--accent-raw:${pal.raw}`}
            data-country={g.data.country}
            data-continent={continentFor(g.data.country)}
            data-start={ex.startISO}
            data-search={`${g.data.country} ${g.data.title} ${g.data.dek || ""} ${continentFor(g.data.country) || ""}`.toLowerCase()}
          >
            {g.id === heroId && <span class="hubcard-featured-tag">Featured above</span>}
            {ex.heroImg ? (
              <span class="hubcard-cover">
                {/* The cover is the shared element that morphs into the guide masthead. The FEATURED
                    guide already carries `cover-<slug>` on the hero above, so its card omits the name
                    to keep it unique per page (a duplicate name disables the transition). */}
                <img class="hubcard-img" src={coverSrc(ex.heroImg)} alt="" loading="lazy" decoding="async"
                     style={g.id === heroId ? undefined : `view-transition-name:cover-${g.id}`} />
                <span class="hubcard-cover-grad" aria-hidden="true"></span>
              </span>
            ) : (
              <span class="hubcard-cover hubcard-cover--typo" aria-hidden="true">
                <span class="hubcard-cover-initial">{g.data.country.slice(0, 1)}</span>
              </span>
            )}
            {/* V5: the accent bar morphs into the guide masthead's own accent rule
                (`.masthead-rule`) on navigation — the palette literally carries across,
                not just coincidentally matches. Same duplicate-name guard as the cover
                photo above (the featured hero has no bar of its own to share the name with,
                so only its grid-card twin gets one). */}
            <span class="hubcard-bar" aria-hidden="true" style={g.id === heroId ? undefined : `view-transition-name:accent-${g.id}`}></span>
            <span class="hubcard-body">
              <span class="hubcard-top">
                <span class="hubcard-country">{g.data.country}</span>
                {ex.badge && <span class="hubcard-badge">{ex.badge}</span>}
              </span>
              <span class="hubcard-title">{g.data.title}</span>
              {g.data.dek && <span class="hubcard-dek">{g.data.dek}</span>}
              <span class="hubcard-meta">
                {ex.dayCount > 0 && <span class="hubcard-days">{ex.dayCount} days</span>}
                {ex.month && <span class="hubcard-days">{ex.month}</span>}
                {(g.data as any).advisory?.level >= 2 && (
                  <span class="hubcard-advisory" title={(g.data as any).advisory.title}>
                    ⚠ Level {(g.data as any).advisory.level} advisory
                  </span>
                )}
              </span>
              <span class="hubcard-go">Open guide →</span>
            </span>
          </a>
          );
        })}
      </div>
      <p class="hub-empty" id="hubEmpty" hidden>No guides match — clear the search or pick another country.</p>
    </main>

    <!-- New-guide quick-start modal -->
    <div class="ng-backdrop" id="ngBackdrop" aria-hidden="true"></div>
    <div class="ng-modal" id="ngModal" role="dialog" aria-modal="true" aria-labelledby="ngHead" data-repo={REPO} hidden>
      <p class="ng-head" id="ngHead">
        Make a new guide
        <button class="ng-close" id="ngClose" type="button" aria-label="Close">✕</button>
      </p>
      <p class="ng-intro">A few details scaffold a new guide — structure, checklists, and live weather/holiday/currency data wired in. It opens a GitHub issue; a research pass then fills the facts.</p>
      <form id="ngForm" class="ng-form">
        <label class="ng-field">
          <span>Country <em>(required)</em></span>
          <input type="text" id="ngCountry" required placeholder="e.g. Brazil" autocomplete="off" />
        </label>
        <label class="ng-field">
          <span>City / cities</span>
          <input type="text" id="ngCities" placeholder="e.g. Rio de Janeiro, São Paulo" autocomplete="off" />
        </label>
        <div class="ng-row">
          <label class="ng-field">
            <span>Start date</span>
            <input type="date" id="ngStart" />
          </label>
          <label class="ng-field">
            <span>End date</span>
            <input type="date" id="ngEnd" />
          </label>
        </div>
        <label class="ng-field">
          <span>Anchor event</span>
          <input type="text" id="ngAnchor" placeholder="e.g. Pokémon GO Wild Area — Mexico City, Nov 6–8 2026" autocomplete="off" />
        </label>
        <label class="ng-field">
          <span>Number of travelers</span>
          <input type="number" id="ngTravelers" min="1" placeholder="e.g. 3" />
        </label>
        <label class="ng-field">
          <span>Who's this for / party</span>
          <input type="text" id="ngParty" placeholder="e.g. the Korea group (3 mid-20s, heavy walkers) / family of 5 with grandparents" autocomplete="off" />
        </label>
        <label class="ng-field">
          <span>Pace</span>
          <select id="ngPace">
            <option value="">undecided</option>
            <option value="packed">packed</option>
            <option value="balanced">balanced</option>
            <option value="slow">slow</option>
          </select>
        </label>
        <label class="ng-field">
          <span>Travel style</span>
          <select id="ngTravelStyle">
            <option value="">undecided</option>
            <option value="Bucket-list must-sees">Bucket-list must-sees</option>
            <option value="Off-the-beaten-path">Off-the-beaten-path</option>
            <option value="Balanced">Balanced</option>
          </select>
        </label>
        {[1, 2, 3].map((n) => (
          <label class="ng-field">
            <span>Priority #{n}{n === 1 && <em> (most important)</em>}</span>
            <select id={`ngPriority${n}`}>
              <option value="">— none —</option>
              <option value="Food & dining">Food & dining</option>
              <option value="Culture / history">Culture / history</option>
              <option value="Nature / outdoors">Nature / outdoors</option>
              <option value="Nightlife">Nightlife</option>
              <option value="Shopping">Shopping</option>
              <option value="Wellness / relaxation">Wellness / relaxation</option>
              <option value="Niche interest (specify below)">Niche interest (specify below)</option>
            </select>
          </label>
        ))}
        <label class="ng-field">
          <span>Niche interest</span>
          <input type="text" id="ngNiche" placeholder="only if a Priority above is Niche — e.g. live music" autocomplete="off" />
        </label>
        <label class="ng-field">
          <span>Budget</span>
          <select id="ngBudget">
            <option value="">undecided</option>
            <option value="Shoestring (<$75/day)">Shoestring (&lt;$75/day)</option>
            <option value="Mid-range ($75–150/day)">Mid-range ($75–150/day)</option>
            <option value="Comfortable ($150–300/day)">Comfortable ($150–300/day)</option>
            <option value="Luxury ($300+/day)">Luxury ($300+/day)</option>
          </select>
        </label>
        <label class="ng-field">
          <span>Comments</span>
          <textarea id="ngComments" rows="2" placeholder="group makeup, dietary needs, a fixed anchor event, dealbreakers, etc."></textarea>
        </label>
        <p class="ng-err" id="ngErr" hidden></p>
        <button type="submit" class="ng-submit">Continue on GitHub →</button>
      </form>
    </div>

    <footer class="hub-foot">Waypoint — every fact checked, every route tested.</footer>

    <script>
      import "../features/hub/index.js";
      import "../scripts/micro.js";
      import { initOverture } from "../scripts/overture.js";
      initOverture();
    </script>

    <!-- A2: the dark-toggle + new-guide-modal script that used to live here (an
         `is:inline define:vars={{ base }}` block, ~95 lines, including a duplicate
         dark-mode-toggle implementation) now boots from the hub silo as real modules —
         see src/features/hub/index.js (initDarkToggle from scripts/theme.js,
         initNewGuideModal from features/hub/ui/new-guide-modal.js), imported via the
         "../features/hub/index.js" import already above. `base` is read there from
         `data-base` on <body> instead of define:vars. -->

  </body>
</html>
