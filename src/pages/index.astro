---
import { getCollection } from "astro:content";
import PwaHead from "../components/PwaHead.astro";
import { accentFor } from "../lib/themes";
import { flattenSections } from "../lib/exports";
// Self-hosted variable fonts (bundled, base-path-safe, offline-correct) — no CDN.
import "@fontsource-variable/bricolage-grotesque";
import "@fontsource-variable/literata";
import "@fontsource-variable/spline-sans-mono";
import "../styles/base.css";
import "../styles/hub.css";
import "../styles/hub-cards.css";

const guides = (await getCollection("guides")).sort((a, b) =>
  a.data.title.localeCompare(b.data.title)
);

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
// Repo the "Make a new guide" button files its GitHub issue against.
const REPO = "Carlob2499/Trip-Guides";

// Trip-date math below intentionally uses LOCAL time (not the UTC parsing in
// lib/holidays.ts) — this badge is "N days away" relative to the visitor's own
// clock, same as the countdown pill in GuideLayout.astro.
const MONTH_MAP: Record<string, number> = {
  Jan:0,Feb:1,Mar:2,Apr:3,May:4,Jun:5,Jul:6,Aug:7,Sep:8,Oct:9,Nov:10,Dec:11
};

function parseTripDate(dateStr: string | undefined): Date | null {
  if (!dateStr) return null;
  const parts = dateStr.split(/\s+/);
  const mon = parts[1]; const d = parseInt(parts[2], 10);
  if (!mon || isNaN(d) || MONTH_MAP[mon] == null) return null;
  const now = new Date();
  const dt  = new Date(now.getFullYear(), MONTH_MAP[mon], d);
  if (dt < now && (now.getTime() - dt.getTime()) > 180 * 86400000) dt.setFullYear(now.getFullYear() + 1);
  return dt;
}

const now = new Date();
const guideExtras = guides.map(g => {
  const flat = flattenSections(g.data.sections as any[] || []);
  const allDays = flat.filter((s: any) => s.type === "days");
  const allItems = allDays.flatMap((s: any) => s.items || []);
  const firstDate = parseTripDate(allItems[0]?.date);
  const lastDate  = parseTripDate(allItems[allItems.length - 1]?.date);
  const dayCount  = allItems.length;
  let badge = "";
  if (firstDate) {
    const diff = Math.round((firstDate.getTime() - now.getTime()) / 86400000);
    if (diff > 1)       badge = diff + " days away";
    else if (diff === 1) badge = "Tomorrow!";
    else if (diff === 0) badge = "Today!";
    else if (diff >= -7) badge = "Now!";
    else if (lastDate && lastDate > now) badge = "In progress";
  }
  // Hero/filter extras — all derivable at build from data the guide already has.
  const mapSec  = flat.find((s: any) => s.type === "map" && typeof s.center?.lat === "number");
  const sight   = flat.filter((s: any) => s.type === "sights").flatMap((s: any) => s.items || []).find((it: any) => it?.img?.file);
  const month   = allItems[0]?.date?.split(/\s+/)[1] || "";
  return {
    dayCount, badge, firstDate, lastDate, month,
    startISO: firstDate ? firstDate.toISOString().slice(0, 10) : "",
    mapCenter: mapSec ? { lat: mapSec.center.lat, lng: mapSec.center.lng } : null,
    heroImg: sight ? { file: sight.img.file, alt: sight.img.alt || sight.name } : null,
  };
});

// Split the curated (verified) grid from the "Guides-to-be" draft tier.
const withExtras = guides.map((g, i) => ({ g, ex: guideExtras[i] }));
const curated = withExtras.filter(x => !x.g.data.draft);
const drafts  = withExtras.filter(x =>  x.g.data.draft);

// Next-trip hero: the curated guide whose trip starts soonest in the future
// (or is in progress right now). None upcoming → the hub keeps its masthead.
const upcoming = curated
  .filter(x => x.ex.firstDate && (x.ex.firstDate >= now || (x.ex.lastDate && x.ex.lastDate >= now)))
  .sort((a, b) => a.ex.firstDate!.getTime() - b.ex.firstDate!.getTime());
const hero = upcoming[0] ?? null;
const heroSrc = hero?.ex.heroImg
  ? `https://commons.wikimedia.org/wiki/Special:FilePath/${encodeURIComponent(hero.ex.heroImg.file)}?width=1400`
  : null;
// Card cover thumbnails — same Commons thumbnailing at grid width.
const coverSrc = (img: { file: string } | null) =>
  img ? `https://commons.wikimedia.org/wiki/Special:FilePath/${encodeURIComponent(img.file)}?width=640` : null;

// Filter chips: one per country that appears in the curated grid.
const countries = [...new Set(curated.map(x => x.g.data.country))].sort();
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Waypoint — Travel Guides</title>
    <PwaHead />
    <!-- Dark-mode init — runs before paint to avoid flash -->
    <script is:inline>
      (function () {
        var s = localStorage.getItem("tg-theme");
        var preferDark = window.matchMedia && window.matchMedia("(prefers-color-scheme:dark)").matches;
        if (s === "dark" || (s === null && preferDark)) {
          document.documentElement.setAttribute("data-theme", "dark");
        } else if (s === "light") {
          document.documentElement.setAttribute("data-theme", "light");
        }
      })();
    </script>
  </head>
  <body>
    <header class="hub-masthead">
      <div class="hub-topbar">
        <button id="btnDark" class="topbar-btn" aria-label="Switch to dark mode" title="Switch to dark mode">◑</button>
      </div>
      <div class="hub-rule" aria-hidden="true"></div>
      <p class="eyebrow">Travel Guides</p>
      <h1>Waypoint</h1>
      <p class="dek">Curated, fact-checked guides — built to be calm to read and easy to follow on the move.</p>
      <p class="hub-count">{curated.length} destinations</p>
      <button id="btnNewGuide" class="hub-new-btn" type="button">＋ Make a new guide</button>
    </header>

    <main class="hub">
      {hero && (
        <a
          class="hub-hero"
          href={`${base}/guides/${hero.g.id}/`}
          style={`--accent:${accentFor(hero.g.data.country)}`}
          data-hero-start={hero.ex.startISO}
          data-hero-lat={hero.ex.mapCenter?.lat}
          data-hero-lng={hero.ex.mapCenter?.lng}
        >
          {heroSrc && (
            <img class="hub-hero-img" src={heroSrc} alt={hero.ex.heroImg!.alt} loading="eager" fetchpriority="high" />
          )}
          <span class="hub-hero-scrim" aria-hidden="true"></span>
          <span class="hub-hero-body">
            <span class="hub-hero-eyebrow">Next trip · {hero.g.data.country}</span>
            <span class="hub-hero-title">{hero.g.data.title}</span>
            <span class="hub-hero-meta">
              <span class="hub-hero-count" data-hero-countdown>{hero.ex.badge}</span>
              <span class="hub-hero-wx" data-hero-wx hidden></span>
              {hero.ex.dayCount > 0 && <span class="hub-hero-days">{hero.ex.dayCount} days planned</span>}
            </span>
            <span class="hub-hero-cta">Open the guide →</span>
          </span>
        </a>
      )}

      <div class="hub-filter" role="search">
        <input class="hub-search" id="hubSearch" type="search" placeholder="Search guides…" aria-label="Search guides" autocomplete="off" />
        <div class="hub-chips" id="hubChips" role="group" aria-label="Filter by country">
          <button class="hub-chip hub-chip-active" type="button" data-filter="">All</button>
          {countries.map((c) => (
            <button class="hub-chip" type="button" data-filter={c}>{c}</button>
          ))}
        </div>
      </div>

      <div class="hub-grid" id="hubGrid">
        {curated.map(({ g, ex }) => (
          <a
            class="hubcard"
            href={`${base}/guides/${g.id}/`}
            style={`--accent:${accentFor(g.data.country)}`}
            data-country={g.data.country}
            data-start={ex.startISO}
            data-search={`${g.data.country} ${g.data.title} ${g.data.dek || ""}`.toLowerCase()}
          >
            {ex.heroImg ? (
              <span class="hubcard-cover">
                <img class="hubcard-img" src={coverSrc(ex.heroImg)} alt="" loading="lazy" decoding="async" />
                <span class="hubcard-cover-grad" aria-hidden="true"></span>
              </span>
            ) : (
              <span class="hubcard-cover hubcard-cover--typo" aria-hidden="true">
                <span class="hubcard-cover-initial">{g.data.country.slice(0, 1)}</span>
              </span>
            )}
            <span class="hubcard-bar" aria-hidden="true"></span>
            <span class="hubcard-body">
              <span class="hubcard-top">
                <span class="hubcard-country">{g.data.country}</span>
                {ex.badge && <span class="hubcard-badge">{ex.badge}</span>}
              </span>
              <span class="hubcard-title">{g.data.title}</span>
              {g.data.dek && <span class="hubcard-dek">{g.data.dek}</span>}
              <span class="hubcard-meta">
                {ex.dayCount > 0 && <span class="hubcard-days">{ex.dayCount} days</span>}
                {ex.month && <span class="hubcard-days">{ex.month}</span>}
              </span>
              <span class="hubcard-go">Open guide →</span>
            </span>
          </a>
        ))}
      </div>
      <p class="hub-empty" id="hubEmpty" hidden>No guides match — clear the search or pick another country.</p>

      {drafts.length > 0 && (
        <section class="hub-drafts" aria-labelledby="draftsHead">
          <div class="hub-drafts-head">
            <h2 id="draftsHead">Guides-to-be</h2>
            <p class="hub-drafts-note">Scaffolds awaiting research — structure and live data are in place, but the facts aren't verified yet.</p>
          </div>
          <div class="hub-grid">
            {drafts.map(({ g }) => (
              <a class="hubcard hubcard--draft" href={`${base}/guides/${g.id}/`} style={`--accent:${accentFor(g.data.country)}`}>
                <span class="hubcard-cover hubcard-cover--typo" aria-hidden="true">
                  <span class="hubcard-cover-initial">{g.data.country.slice(0, 1)}</span>
                </span>
                <span class="hubcard-bar" aria-hidden="true"></span>
                <span class="hubcard-body">
                  <span class="hubcard-top">
                    <span class="hubcard-country">{g.data.country}</span>
                    <span class="hubcard-badge hubcard-badge--draft">Draft</span>
                  </span>
                  <span class="hubcard-title">{g.data.title}</span>
                  <span class="hubcard-dek">Template ready · needs a research pass</span>
                  <span class="hubcard-go">Open scaffold →</span>
                </span>
              </a>
            ))}
          </div>
        </section>
      )}
    </main>

    <!-- New-guide quick-start modal -->
    <div class="ng-backdrop" id="ngBackdrop" aria-hidden="true"></div>
    <div class="ng-modal" id="ngModal" role="dialog" aria-modal="true" aria-labelledby="ngHead" data-repo={REPO} hidden>
      <p class="ng-head" id="ngHead">
        Make a new guide
        <button class="ng-close" id="ngClose" type="button" aria-label="Close">✕</button>
      </p>
      <p class="ng-intro">A few details scaffold a new guide — structure, checklists, and live weather/holiday/currency data wired in. It opens a GitHub issue; a research pass then fills the facts.</p>
      <form id="ngForm" class="ng-form">
        <label class="ng-field">
          <span>Country <em>(required)</em></span>
          <input type="text" id="ngCountry" required placeholder="e.g. Brazil" autocomplete="off" />
        </label>
        <label class="ng-field">
          <span>City / cities</span>
          <input type="text" id="ngCities" placeholder="e.g. Rio de Janeiro, São Paulo" autocomplete="off" />
        </label>
        <div class="ng-row">
          <label class="ng-field">
            <span>Start date</span>
            <input type="date" id="ngStart" />
          </label>
          <label class="ng-field">
            <span>End date</span>
            <input type="date" id="ngEnd" />
          </label>
        </div>
        <label class="ng-field">
          <span>Number of travelers</span>
          <input type="number" id="ngTravelers" min="1" placeholder="e.g. 3" />
        </label>
        <label class="ng-field">
          <span>Pace</span>
          <select id="ngPace">
            <option value="">undecided</option>
            <option value="packed">packed</option>
            <option value="balanced">balanced</option>
            <option value="slow">slow</option>
          </select>
        </label>
        {[1, 2, 3].map((n) => (
          <label class="ng-field">
            <span>Priority #{n}{n === 1 && <em> (most important)</em>}</span>
            <select id={`ngPriority${n}`}>
              <option value="">— none —</option>
              <option value="Food & dining">Food & dining</option>
              <option value="Culture / history">Culture / history</option>
              <option value="Nature / outdoors">Nature / outdoors</option>
              <option value="Nightlife">Nightlife</option>
              <option value="Shopping">Shopping</option>
              <option value="Wellness / relaxation">Wellness / relaxation</option>
              <option value="Niche interest (specify below)">Niche interest (specify below)</option>
            </select>
          </label>
        ))}
        <label class="ng-field">
          <span>Niche interest</span>
          <input type="text" id="ngNiche" placeholder="only if a Priority above is Niche — e.g. live music" autocomplete="off" />
        </label>
        <label class="ng-field">
          <span>Budget</span>
          <select id="ngBudget">
            <option value="">undecided</option>
            <option value="Shoestring (<$75/day)">Shoestring (&lt;$75/day)</option>
            <option value="Mid-range ($75–150/day)">Mid-range ($75–150/day)</option>
            <option value="Comfortable ($150–300/day)">Comfortable ($150–300/day)</option>
            <option value="Luxury ($300+/day)">Luxury ($300+/day)</option>
          </select>
        </label>
        <label class="ng-field">
          <span>Comments</span>
          <textarea id="ngComments" rows="2" placeholder="group makeup, dietary needs, a fixed anchor event, dealbreakers, etc."></textarea>
        </label>
        <p class="ng-err" id="ngErr" hidden></p>
        <button type="submit" class="ng-submit">Continue on GitHub →</button>
      </form>
    </div>

    <footer class="hub-foot">Waypoint — every fact checked, every route tested.</footer>

    <script>
      import "../scripts/hub.js";
    </script>

    <script is:inline>
      (function () {
        var darkBtn = document.getElementById("btnDark");
        function syncDark() {
          var dark = document.documentElement.getAttribute("data-theme") === "dark";
          if (!darkBtn) return;
          darkBtn.textContent = dark ? "☀" : "◑";
          darkBtn.setAttribute("aria-label", dark ? "Switch to light mode" : "Switch to dark mode");
          darkBtn.title = dark ? "Switch to light mode" : "Switch to dark mode";
        }
        syncDark();
        if (darkBtn) {
          darkBtn.addEventListener("click", function () {
            var dark = document.documentElement.getAttribute("data-theme") === "dark";
            var next = dark ? "light" : "dark";
            document.documentElement.setAttribute("data-theme", next);
            try { localStorage.setItem("tg-theme", next); } catch (e) {}
            syncDark();
          });
        }

        /* ── New-guide modal ── */
        var openBtn  = document.getElementById("btnNewGuide");
        var modal    = document.getElementById("ngModal");
        var backdrop = document.getElementById("ngBackdrop");
        var closeBtn = document.getElementById("ngClose");
        var form     = document.getElementById("ngForm");
        var errEl    = document.getElementById("ngErr");
        if (!openBtn || !modal) return;
        var repo = modal.getAttribute("data-repo");

        function openModal() {
          modal.removeAttribute("hidden");
          backdrop.classList.add("open");
          var c = document.getElementById("ngCountry"); if (c) c.focus();
        }
        function closeModal() {
          modal.setAttribute("hidden", "");
          backdrop.classList.remove("open");
          openBtn.focus();
        }
        openBtn.addEventListener("click", openModal);
        if (closeBtn) closeBtn.addEventListener("click", closeModal);
        if (backdrop) backdrop.addEventListener("click", closeModal);
        document.addEventListener("keydown", function (e) {
          if (e.key === "Escape" && !modal.hasAttribute("hidden")) closeModal();
        });

        function val(id) { var el = document.getElementById(id); return el ? el.value.trim() : ""; }

        if (form) {
          form.addEventListener("submit", function (e) {
            e.preventDefault();
            var country = val("ngCountry");
            if (!country) {
              if (errEl) { errEl.textContent = "Country is required."; errEl.removeAttribute("hidden"); }
              return;
            }
            var dates = [val("ngStart"), val("ngEnd")].filter(Boolean).join(" to ");
            var params = new URLSearchParams();
            params.set("template", "new-guide.yml");
            params.set("labels", "new-guide");
            params.set("title", "New guide: " + country);
            params.set("country", country);
            params.set("cities", val("ngCities"));
            params.set("dates", dates);
            params.set("travelers", val("ngTravelers"));
            params.set("pace", val("ngPace"));
            params.set("priority1", val("ngPriority1"));
            params.set("priority2", val("ngPriority2"));
            params.set("priority3", val("ngPriority3"));
            params.set("niche", val("ngNiche"));
            params.set("budget", val("ngBudget"));
            params.set("comments", val("ngComments"));
            var url = "https://github.com/" + repo + "/issues/new?" + params.toString();
            window.open(url, "_blank", "noopener");
            closeModal();
          });
        }
      })();
    </script>
  </body>
</html>
