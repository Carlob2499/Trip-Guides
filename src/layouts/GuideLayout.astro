---
import Block from "../components/Block.astro";
import PwaHead from "../components/PwaHead.astro";
import TripSplit from "../components/TripSplit.astro";
import Voting from "../components/Voting.astro";
import { bucket } from "../lib/buckets";
import { EMERGENCY } from "../data/countries.mjs";
import { accentFor, darken, currencyFor, tzFor, COUNTRY_CODES } from "../lib/themes";
import { buildHolidayInfo, deriveTripYear } from "../lib/holidays";
import { collectWaypoints, collectDayEvents, buildSummary } from "../lib/exports";
// Self-hosted variable fonts (bundled, base-path-safe, offline-correct) — no CDN.
import "@fontsource-variable/bricolage-grotesque";
import "@fontsource-variable/literata";
import "@fontsource-variable/spline-sans-mono";
import "../styles/base.css";
import "../styles/guide.css";
import "../styles/masthead.css";
import "../styles/sights.css";
import "../styles/map.css";
import "../styles/planner.css";
import "../styles/overview.css";
import "../styles/flight.css";
import "../styles/mobile-nav.css";
import "../styles/field-tools.css";
import "../styles/palette.css";
import "../styles/print-day.css";
import "../features/firebase/live.css";
import { derivePins } from "../lib/map-pins";

// Build-time public-holiday data (Nager.Date), written by scripts/fetch-holidays.mjs
// into src/data/holidays/{CC}-{year}.json and refreshed by CI before each build.
// Eagerly imported so it's inlined at build with no client fetch. Empty object if
// no files exist yet — the holiday block then simply hides.
const holidayData = import.meta.glob("../data/holidays/*.json", { eager: true, import: "default" }) as Record<string, any[]>;

// Same repo identifier index.astro's New-guide modal already uses for its
// prefilled-issue link — kept as a local constant there too (no shared
// site-config module exists yet for a single string this small).
const REPO = "Carlob2499/Trip-Guides";

const { guide } = Astro.props;
const { order, byG } = bucket(guide.sections);

// Tab-bar display shortening: long compound group names crowd the tab strip
// (Korea has 13 tabs; names run to 20 chars). Display-only — the full name
// stays in aria-label, the sheet, the dial, and the chapter opener. Data is
// untouched. Rule: names over 13 chars split at " & " keep the head.
const shortLabel = (g: string) =>
  g.length > 13 && g.includes(" & ") ? g.split(" & ")[0] : g;

// Chapter-opener photo fans: a group whose sections already carry verified
// Commons images (sights) gets up to three of its OWN photos fanned beside
// the opener numeral. Pure derivation — no new sourcing, no invented files.
const groupImgs: Record<string, { file: string; alt: string }[]> = {};
for (const g of order) {
  const imgs = byG[g]
    .filter((o: any) => o.s.type === "sights")
    .flatMap((o: any) => o.s.items || [])
    .filter((it: any) => it?.img?.file)
    .slice(0, 3)
    .map((it: any) => ({ file: it.img.file, alt: it.img.alt || it.name || "" }));
  if (imgs.length) groupImgs[g] = imgs;
}
const thumbSrc = (f: string) =>
  `https://commons.wikimedia.org/wiki/Special:FilePath/${encodeURIComponent(f)}?width=320`;
// A guide may override the country-derived palette with an explicit `theme`
// (primary/secondary/accent, contrast-gated at build time). When absent — every
// guide today — `accent` stays exactly the country colour, so no guide regresses.
// `theme.primary` drives the existing `--accent` (all accent-coloured UI); the
// three `--theme-*` vars are exposed for opt-in use (e.g. focus rings) and simply
// equal the country accent when no theme is set, so `var(--theme-primary)` is
// always safe.
const accent  = guide.theme?.primary ?? accentFor(guide.country);
const accent2 = darken(accent, 0.14);
const themePrimary   = guide.theme?.primary   ?? accent;
const themeSecondary = guide.theme?.secondary ?? accent;
const themeAccent    = guide.theme?.accent    ?? accent;
const storeKey = (guide.title || "guide").replace(/\W+/g, "").toLowerCase();
const navLabel = (s: any, g: string) => s.title || s.name || g;
const localCur = currencyFor(guide.country);

// Destination IANA time zone (e.g. "Asia/Seoul") — sourced from the country table.
// The client uses Intl with this, so the local-time pill + jet-lag calc are DST-correct.
const destTzIana = tzFor(guide.country);

// Base path for the deploy (e.g. "/Trip-Guides" on GitHub Pages). Astro does not
// auto-prepend the base to string/template hrefs, so home links build it explicitly.
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

// OG/Twitter image lives at {base}/og/{slug}.png (generated by pages/og/[slug].png.ts).
// Build it from the base + the last path segment so it works under the subpath —
// the old code stripped "^/guides/" which never matched "/Trip-Guides/guides/...",
// producing a double-slash, wrong-path URL.
const ogSlug  = Astro.url.pathname.split("/").filter(Boolean).pop();
const ogImage = `${Astro.url.origin}${base}/og/${ogSlug}.png`;

// Compute at-a-glance stats for the masthead stat bar
function flatSections(secs: any[]): any[] {
  return secs.flatMap((s: any) => s.sections ? flatSections(s.sections) : [s]);
}
const _flat = flatSections(guide.sections || []);
const dayCount   = _flat.filter((s: any) => s.type === "days"  ).reduce((n: number, s: any) => n + (s.items?.length || 0), 0);
const sightCount = _flat.filter((s: any) => s.type === "sights").reduce((n: number, s: any) => n + (s.items?.length || 0), 0);

// Masthead hero image — the first sights item that carries a Commons photo.
// Present → full-bleed photo hero; absent (scaffolds) → bold typographic hero
// on the accent field. Same Commons Special:FilePath thumbnailing as SightsBlock.
const heroSight = _flat
  .filter((s: any) => s.type === "sights")
  .flatMap((s: any) => s.items || [])
  .find((it: any) => it?.img?.file);
const heroSrc = heroSight
  ? `https://commons.wikimedia.org/wiki/Special:FilePath/${encodeURIComponent(heroSight.img.file)}?width=1600`
  : null;
const heroCredit = heroSight
  ? `https://commons.wikimedia.org/wiki/File:${encodeURIComponent(heroSight.img.file)}`
  : null;

// For weather widget — pull lat/lng from first map section
const mapSec    = _flat.find((s: any) => s.type === "map" && s.center?.lat);
const mapCenter = mapSec ? { lat: mapSec.center.lat as number, lng: mapSec.center.lng as number } : null;

// When a guide has its own `weather` section, that section provides the #wxWrap
// mount in-flow, so the masthead strip is suppressed (no double render). The flag
// is also passed to the client so the service can log a breadcrumb if a weather
// section exists but there's no map section to source coordinates from.
const hasWeatherSection = _flat.some((s: any) => s.type === "weather");

// Map-section pins (build-time; first map gets all sights). Consumed only by
// the opt-in Google renderer (gmaps-render.js) when a key is set; the default
// OSM iframe ignores them.
const pinMap = derivePins(guide.sections);

// For trip countdown — pull first date string from first days section (e.g. "Wed Jul 8")
const daysSec      = _flat.find((s: any) => s.type === "days" && s.items?.length);
const firstDayDate = (daysSec?.items?.[0]?.date as string) ?? null;
const lastDayDate  = (daysSec?.items?.[daysSec.items.length - 1]?.date as string) ?? firstDayDate;

// What's-Next banner: compact per-day slice for the client to match against
// today's device-local date. No coordinates/time-of-day in the schema — day
// granularity only, same as the trip-countdown pill's own date parsing.
const daysForBanner = (daysSec?.items ?? []).map((d: any) => ({
  date: d.date as string, title: d.title as string, fit: (d.fit as string) ?? null,
}));

// `verified` is source metadata (freshness tracking for the maker/AI), not shown to
// travelers — EXCEPT genuine ⚠ warnings (e.g. an unconfirmed draft), which stay visible.
const verifiedWarning = guide.verified?.trimStart().startsWith("⚠") ? guide.verified : null;
// Freshness date for the masthead chip — the ISO date inside the verified
// stamp when present (surfaced, never invented; no date → no chip).
const verifiedDate = guide.verified?.match(/\d{4}-\d{2}-\d{2}/)?.[0] ?? null;

// Public holidays — if the guide has a `holidays` section, look up the build-time
// data for this country + trip year and slice it around the trip dates. All
// server-side; the block hides when there's no country mapping or no data file.
const holSec = _flat.find((s: any) => s.type === "holidays");
let holidayInfo = null;
if (holSec) {
  const cc = COUNTRY_CODES[guide.country] || null;
  const holYear = holSec.year || deriveTripYear(firstDayDate);
  const all = cc ? holidayData[`../data/holidays/${cc}-${holYear}.json`] : null;
  holidayInfo = buildHolidayInfo(all ?? null, firstDayDate, lastDayDate, holYear);
}

// Build-time export availability. A guide gets a .gpx only if it has at least one
// map/sights coordinate, and a .ics only if it has at least one parseable day card —
// the same filters the endpoints use. Each download link is shown only when its
// file exists, so a guide missing that data simply doesn't offer it (Principle 5).
const hasWaypoints = collectWaypoints(guide).length > 0;
const hasDayEvents = collectDayEvents(guide).length > 0;


// Plain-text trip digest for the "Share summary" button (theme + planned days +
// key spots). Embedded in a hidden element; the client reads its textContent and
// appends the page URL at share time.
const tripSummary = buildSummary(guide);
---
<!doctype html>
<html lang="en" style={`--accent:${accent};--accent2:${accent2};--theme-primary:${themePrimary};--theme-secondary:${themeSecondary};--theme-accent:${themeAccent}`}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{guide.title} — Trip Guide</title>
    <meta name="description" content={guide.dek || guide.title} />
    {/* Drafts stay fully viewable/linkable (the homepage's Guides-to-be tier links
        directly to them) — only search indexing is suppressed in production, since
        the content isn't verified yet. Never applied in dev, so drafts are
        inspectable exactly like any other guide while working on them. */}
    {guide.draft && import.meta.env.PROD && (
      <meta name="robots" content="noindex, nofollow" />
    )}
    <meta property="og:type"        content="article" />
    <meta property="og:title"       content={`${guide.title} — Trip Guide`} />
    <meta property="og:description" content={guide.dek || guide.title} />
    <meta property="og:url"         content={Astro.url.href} />
    <meta property="og:image"       content={ogImage} />
    <meta name="twitter:card"       content="summary_large_image" />
    <meta name="twitter:title"      content={`${guide.title} — Trip Guide`} />
    <meta name="twitter:description" content={guide.dek || guide.title} />
    <meta name="twitter:image"      content={ogImage} />
    <link rel="canonical"           href={Astro.url.href} />
    <PwaHead />
    <!--
      Inline dark-mode init: runs synchronously before first paint so there's
      no flash of the wrong theme. Reads localStorage then falls back to the
      OS prefers-color-scheme preference.
    -->
    <script is:inline>
      (function () {
        var s = localStorage.getItem("tg-theme");
        var preferDark = window.matchMedia && window.matchMedia("(prefers-color-scheme:dark)").matches;
        if (s === "dark" || (s === null && preferDark)) {
          document.documentElement.setAttribute("data-theme", "dark");
        } else if (s === "light") {
          document.documentElement.setAttribute("data-theme", "light");
        }
      })();
    </script>
  </head>

  <body data-storekey={storeKey}>

    <!-- Skip link — first focusable element; jumps keyboard/AT users past the
         chrome straight to the content. -->
    <a class="skip-link" href="#content">Skip to content</a>

    <!-- Reading progress bar — fixed 3px line at top, fills as user scrolls -->
    <div id="readProg" class="read-prog" aria-hidden="true"></div>

    <!-- Transient toast — destination for flash() (save/copy confirmations).
         Was previously inline in the checklist progress bar; relocated here as a
         standalone toast so feedback survives that bar's removal. -->
    <div id="savedNote" class="toast" role="status" aria-live="polite"></div>

    <!-- Sticky chrome: topbar + guide tab bar stick together as a unit -->
    <div class="sticky-chrome">

    <!-- ═══════════════════════════════════════════════════════════════════════
         TOP NAVIGATION BAR
         ═══════════════════════════════════════════════════════════════════ -->
    <nav class="topbar" aria-label="Site navigation">
      <a href={`${base}/`} class="topbar-home" aria-label="All guides">
        <svg width="14" height="10" viewBox="0 0 14 10" fill="none" aria-hidden="true">
          <path d="M1 5h12M1 5l4-4M1 5l4 4" stroke="currentColor" stroke-width="1.6"
                stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span class="topbar-wordmark">Waypoint</span>
      </a>
      <div class="topbar-right">
        <!-- Search + SOS buttons are injected into this cluster by palette.js /
             sos.js so they share the chrome-button styling. -->
        <button id="btnShare" class="topbar-btn" aria-label="Share this guide" title="Share this guide"><svg class="tb-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><path d="m8.6 13.5 6.8 4M15.4 6.5l-6.8 4"/></svg> <span class="tb-label">Share</span></button>
        <!--
          Dark-mode toggle — icon and aria-label are updated by JS.
          ◑ = currently light → click to go dark
          ☀ = currently dark  → click to go light
        -->
        <button id="btnDark" class="topbar-btn" aria-label="Switch to dark mode" title="Switch to dark mode">◑</button>
      </div>
    </nav>

    <!-- Share modal — hidden until btnShare is clicked; skipped by Web Share API on mobile -->
    <div class="share-backdrop" id="shareBackdrop" aria-hidden="true"></div>
    <div class="share-modal" id="shareModal" role="dialog" aria-modal="true" aria-label="Share this guide" hidden>
      <p class="share-head">
        Share this guide
        <button class="share-close" id="shareClose" type="button" aria-label="Close">✕</button>
      </p>
      <div class="share-qr-wrap"><div id="shareQr"></div></div>
      <div class="share-url-row">
        <span class="share-url-txt" id="shareUrlTxt" title="Guide URL"></span>
        <button class="share-copy-btn" id="shareCopyBtn" type="button">Copy link</button>
      </div>
      {(hasDayEvents || hasWaypoints) && (
        <button class="share-summary-btn" id="btnShareSummary" type="button">↗ Share trip summary</button>
      )}
      <!-- Plain-text trip digest; read by the Share-summary handler via textContent -->
      <div id="tripSummary" hidden>{tripSummary}</div>
      <div class="share-socials">
        <a class="share-soc" id="shareWA" href="#" target="_blank" rel="noopener noreferrer">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.47 14.38c-.3-.15-1.75-.86-2.02-.96s-.47-.15-.66.15-.76.96-.93 1.16-.34.22-.64.07a8.06 8.06 0 0 1-2.37-1.46 8.9 8.9 0 0 1-1.64-2.04c-.17-.3 0-.46.13-.6s.3-.35.44-.52a2 2 0 0 0 .3-.5.55.55 0 0 0-.03-.52c-.07-.15-.66-1.6-.91-2.19-.24-.57-.48-.49-.66-.5h-.57a1.1 1.1 0 0 0-.8.37 3.36 3.36 0 0 0-1.05 2.5 5.84 5.84 0 0 0 1.22 3.1c.15.2 2.1 3.2 5.08 4.49a17.1 17.1 0 0 0 1.7.63 4.1 4.1 0 0 0 1.87.12 3.08 3.08 0 0 0 2.02-1.43 2.5 2.5 0 0 0 .17-1.43c-.07-.13-.26-.2-.56-.35M12 2a10 10 0 0 0-8.67 14.97L2 22l5.18-1.36A10 10 0 1 0 12 2"/></svg>
          WhatsApp
        </a>
        <a class="share-soc" id="shareEmail" href="#">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          Email
        </a>
      </div>
      <p class="share-install">📲 <b>Save this guide to your phone:</b> open your browser menu and choose <i>Add to Home Screen</i> — it then works offline for the whole trip (maps and photos still need a connection).</p>
      {(hasWaypoints || hasDayEvents) && (
        <div class="share-downloads">
          <p class="share-dl-head">Take it with you</p>
          <div class="share-dl-row">
            {hasWaypoints && (
              <a class="share-dl" href={`${base}/guides/${ogSlug}.gpx`} download={`${ogSlug}.gpx`}>
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                Map points <span class="share-dl-ext">.gpx</span>
              </a>
            )}
            {hasDayEvents && (
              <a class="share-dl" href={`${base}/guides/${ogSlug}.ics`} download={`${ogSlug}.ics`}>
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
                Trip calendar <span class="share-dl-ext">.ics</span>
              </a>
            )}
          </div>
        </div>
      )}
    </div>

    <!-- ═══════════════════════════════════════════════════════════════════════
         GUIDE TAB BAR — one tab per section group + Budget Calculator + Vote tools
         ═══════════════════════════════════════════════════════════════════ -->
    <nav class="guide-tabs" id="guideTabs" role="tablist" aria-label="Guide sections">
      {order.map((g, i) => (
        <button class="gtab" role="tab" type="button" data-tab={i} data-full={g}
                aria-label={g} aria-selected={i === 0 ? "true" : "false"}>{shortLabel(g)}</button>
      ))}
      <button class="gtab gtab-split" role="tab" type="button" data-tab="split"
              aria-selected="false">$ Budget</button>
      <button class="gtab gtab-vote" role="tab" type="button" data-tab="vote"
              aria-selected="false">🗳 Vote</button>
    </nav>

    </div>{/* end .sticky-chrome */}

    <!-- ═══════════════════════════════════════════════════════════════════════
         MASTHEAD
         ═══════════════════════════════════════════════════════════════════ -->
    <header class={`masthead mast-hero ${heroSrc ? "mast-photo" : "mast-typo"}`} id="top" data-hero>
      <div class="mast-frame">
        {heroSrc && (
          <img class="mast-img" src={heroSrc} alt={heroSight.img.alt || heroSight.name || ""}
               loading="eager" fetchpriority="high" />
        )}
        <span class="mast-scrim" aria-hidden="true"></span>
        <div class="mast-inner">
          {/* Dedup guard: never render the eyebrow if it would repeat the
              title verbatim (e.g. title "South Korea", country "South Korea").
              A kicker always wins; otherwise the country shows only when it
              adds information. */}
          {(guide.kicker || guide.country !== guide.title) && (
            <p class="eyebrow mast-eyebrow">{guide.kicker || guide.country}</p>
          )}
          <h1 class="mast-title">{guide.title}</h1>
          {guide.dek && <p class="dek mast-dek">{guide.dek}</p>}
        </div>
        {heroCredit && (
          <a class="mast-credit" href={heroCredit} target="_blank" rel="noopener" aria-label="Photo source on Wikimedia Commons">Photo: Wikimedia Commons ↗</a>
        )}
      </div>
      <div class="masthead-rule" aria-hidden="true"></div>

      <!-- What's-Next banner — populated client-side against the device clock;
           FIRST in the masthead flow because it's the most actionable element
           during the trip ("what am I doing today"). Hidden outside the trip's
           own date range. -->
      <div class="whats-next" id="whatsNext" hidden>
        <span class="wn-label" id="wnLabel">Today</span>
        <span class="wn-text" id="wnText"></span>
      </div>

      <!-- Weather strip — populated by JS via Open-Meteo if guide has a map section.
           Suppressed when the guide has its own `weather` section (which mounts
           #wxWrap in-flow instead), so weather never renders twice. -->
      {!hasWeatherSection && (
        <div id="wxWrap" class="wx-wrap" hidden><div id="wxMount"></div></div>
      )}

      <!-- Stats bar — always rendered so JS can inject dynamic pills -->
      <div class="guide-stats" id="guideStats">
        {dayCount   > 0 && <span class="gstat">{dayCount} days</span>}
        {sightCount > 0 && <span class="gstat">{sightCount} sights</span>}
        {verifiedWarning && <span class="gstat gstat-warning">{verifiedWarning}</span>}
        <!-- Live currency rate injected by JS when fetch succeeds -->
        <span class="gstat gstat-rate" id="liveRatePill" hidden></span>
      </div>

      {guide.draft && (
        <!-- Anyone can nominate; nothing here actually publishes anything — the
             linked issue only auto-applies "graduate-request". Only the owner
             applying "graduate-approved" (requires write access) flips draft:false,
             via .github/workflows/graduate-guide.yml. -->
        <p class="draft-graduate">
          <a
            class="draft-graduate-link"
            href={`https://github.com/${REPO}/issues/new?template=graduate-guide.yml&labels=graduate-request&slug=${encodeURIComponent(ogSlug)}&title=${encodeURIComponent(`Graduate: ${ogSlug}`)}`}
            target="_blank" rel="noopener"
          >✓ Think this is ready? Nominate it for graduation</a>
        </p>
      )}

      <!--
        JET-LAG CALCULATOR
        Collapsible — shown only when the guide's country has a known UTC offset.
        User picks their origin timezone; output shows the time gap, recovery
        estimate, and direction-specific tips.
      -->
      {destTzIana !== null && (
        <div class="jl-wrap">
          <button class="jl-toggle" id="jlToggle" type="button"
                  aria-expanded="false" aria-controls="jlPanel">
            <span class="jl-icon" aria-hidden="true">✈</span>
            <span>Jet-lag calculator</span>
            <span class="jl-chev" aria-hidden="true">▾</span>
          </button>
          <div id="jlPanel" hidden data-dest-tz={destTzIana}>
            <div class="jl-inner">
              <div class="jl-row">
                <label class="jl-label" for="jlOrigin">Flying&nbsp;from</label>
                <select class="jl-select" id="jlOrigin">
                  <option value="">— pick your departure city —</option>
                  <optgroup label="United States">
                    <option value="-7">Los Angeles / Pacific (PDT, UTC−7)</option>
                    <option value="-6">Denver / Mountain (MDT, UTC−6)</option>
                    <option value="-5">Chicago / Central (CDT, UTC−5)</option>
                    <option value="-4">New York / Eastern (EDT, UTC−4)</option>
                  </optgroup>
                  <optgroup label="Other cities">
                    <option value="0">London (BST, UTC+0)</option>
                    <option value="1">Lisbon (WEST, UTC+1)</option>
                    <option value="2">Paris / Berlin / Madrid (CEST, UTC+2)</option>
                    <option value="3">Helsinki / Athens / Nairobi (UTC+3)</option>
                    <option value="4">Dubai (UTC+4)</option>
                    <option value="5.5">Mumbai / Delhi (IST, UTC+5:30)</option>
                    <option value="7">Bangkok (ICT, UTC+7)</option>
                    <option value="8">Singapore / Hong Kong / Beijing (UTC+8)</option>
                    <option value="9">Tokyo / Seoul (JST/KST, UTC+9)</option>
                    <option value="10">Sydney (AEST, UTC+10)</option>
                    <option value="12">Auckland (NZST, UTC+12)</option>
                  </optgroup>
                </select>
              </div>
              <!-- Output injected by JS -->
              <div class="jl-output" id="jlOutput" hidden></div>
            </div>
          </div>
        </div>
      )}
    </header>

    <!-- ═══════════════════════════════════════════════════════════════════════
         MAIN LAYOUT — tab-switched content panels (nav is the sticky tab bar above)
         ═══════════════════════════════════════════════════════════════════ -->
    <div class="shell">
      <main class="content" id="content" role="tabpanel">
        <noscript>
          <p class="note" style="padding:1.5rem 0">This guide reads fine without JavaScript; enabling it adds section tabs, saved checklists, and the jet-lag calculator.</p>
        </noscript>
        {order.map((g, ci) => {
          const solo = byG[g].length === 1;
          // Chapter-opener contents line: what's inside, derived from the
          // section titles already in the data (no invented copy).
          const subParts = solo ? [] : byG[g].map((o) => navLabel(o.s, g)).filter((t: string) => t && t !== g);
          const sub = subParts.slice(0, 4).join(" · ") + (subParts.length > 4 ? ` · +${subParts.length - 4} more` : "");
          return (
            <div class="catblock" id={`grp-${ci}`} data-ci={ci} hidden={ci > 0}>
              <header class="cat-opener">
                <span class="cat-num" aria-hidden="true">{String(ci + 1).padStart(2, "0")}</span>
                {groupImgs[g] && (
                  <span class="cat-fan" aria-hidden="true">
                    {groupImgs[g].map((im, fi) => (
                      <img class={`cat-fan-img cat-fan-${fi}`} src={thumbSrc(im.file)} alt="" loading="lazy" decoding="async" />
                    ))}
                  </span>
                )}
                <h2 class="cat-title">{g}</h2>
                {sub && <p class="cat-sub">{sub}</p>}
              </header>
              {byG[g].map((o) => (
                <Block sec={o.s} sid={`sec-${o.i}`} ci={ci} solo={solo} holidays={holidayInfo} mapPins={pinMap.get(o.s) ?? null} />
              ))}
              {ci < order.length - 1 && (
                <button class="next-cta" type="button" data-next-tab={ci + 1}>
                  <span class="next-cta-label">Next section</span>
                  <span class="next-cta-title">{order[ci + 1]}</span>
                  <span class="next-cta-arrow" aria-hidden="true">→</span>
                </button>
              )}
            </div>
          );
        })}
        <TripSplit storeKey={storeKey} />
        <Voting storeKey={storeKey} />
      </main>
    </div>

    <footer>
      {guide.footer}
      <br />
      <span class="offline-note">Add this to your home screen and it works offline once opened — only the embedded maps need a connection.</span>
    </footer>

    <!-- ═══════════════════════════════════════════════════════════════════════
         MOBILE BOTTOM BAR (hidden on desktop)
         Three touch targets: Home | Sections (flex-1) | ↑ Top
         · Home     — one tap back to the guide list, always reachable
         · Sections — opens the slide-up section sheet
         · ↑        — scroll to top
         ═══════════════════════════════════════════════════════════════════ -->
    <div class="botbar">
      <a class="botHome" href={`${base}/`} aria-label="All guides" title="All guides">⌂</a>
      <button class="botSections" id="sheetOpen" type="button"
              aria-haspopup="dialog" aria-expanded="false">
        <span class="bs-label">Sections</span>
        <span class="bs-cur" id="curCat"></span>
        <span class="bs-chev" aria-hidden="true">▾</span>
      </button>
      <a class="botTop" href="#top" aria-label="Back to top">↑</a>
    </div>

    <!-- Slide-up section sheet (mobile) -->
    <div class="sheet-backdrop"></div>
    <div class="sheet" role="dialog" aria-label="Sections" aria-modal="true">
      <div class="sheet-grip" aria-hidden="true"></div>
      <div class="sheet-head">Jump to a section</div>
      <div class="sheet-list">
        {order.map((g, ci) => (
          <>
            <a class="sheet-cat" data-cat={ci} data-tab={ci} href={`#grp-${ci}`}>{g}</a>
            {byG[g].length > 1 && byG[g].map((o) => (
              <a class="sheet-link" data-tab={ci} href={`#sec-${o.i}`}>{navLabel(o.s, g)}</a>
            ))}
          </>
        ))}
        <a class="sheet-cat sheet-split-link" data-tab="split" href="#">$ Budget Calculator</a>
        <a class="sheet-cat sheet-vote-link" data-tab="vote" href="#">🗳 Group Vote</a>
      </div>
    </div>

    <!-- ═══════════════════════════════════════════════════════════════════════
         CLIENT SCRIPT
         All interactive enhancements in one bundle:
           1. Dark-mode toggle
           2. Mobile sheet (open/close, Escape, focus-trap)
           3. Scroll-spy (highlights current section in nav)
           4. Checklists (save to localStorage, export/import/clear)
           5. Budget calculators (live total, persisted per-device)
           6. Jet-lag calculator
         ═══════════════════════════════════════════════════════════════════ -->
    <!-- Config for the extracted guide UI module (formerly Astro define:vars). -->
    <script type="application/json" id="tgConfig" set:html={JSON.stringify({ order, storeKey, mapCenter, firstDayDate, lastDayDate, hasWeatherSection, destTzIana, curCode: localCur?.code ?? null, curFallbackRate: localCur?.approxRate ?? null, daysForBanner, gmapsKey: import.meta.env.PUBLIC_GMAPS_KEY ?? null, gmapsMapId: import.meta.env.PUBLIC_GMAPS_MAP_ID ?? null, emergency: EMERGENCY[guide.country] ?? null, verifiedDate })}></script>
    <!-- Interactive UI — bundled + hashed by Astro into one module shared across guides. -->
    <script>
      import "../scripts/guide-ui.js";
      import "../scripts/gmaps-render.js";
      import "../scripts/day-rail.js";
      import "../scripts/reveal.js";
      import "../scripts/section-flight.js";
      import "../scripts/swipe-nav.js";
      import "../scripts/micro.js";
      import "../scripts/onboard.js";
      import "../scripts/scroll-memory.js";
      import "../scripts/now-line.js";
      import "../scripts/offline-pill.js";
      import "../scripts/field-tools.js";
      import "../scripts/sos.js";
      import "../scripts/lightbox.js";
      import "../scripts/spine.js";
      import "../scripts/hero-parallax.js";
      import "../scripts/gsap-hero.js";
      import "../scripts/palette.js";
      import "../scripts/print-day.js";
      import "../scripts/trip-split.js";
    </script>

  </body>
</html>
